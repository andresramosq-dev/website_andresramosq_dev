---
import '../styles/dev.css';
import TerminalShell from '../components/TerminalShell.astro';
import { site, nav } from '../data/site';

interface Props {
	title?: string;
	description?: string;
	path?: string;
}

const { title, description, path = '/about' } = Astro.props;
const pageTitle = title ? `${title} — ${site.domain}` : site.domain;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? site.description} />
    <meta name="author" content={site.name} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>

    <div class="desk">
      <TerminalShell>
        <header class="term-hd">
          <nav class="nav" aria-label="Routes">
            {nav.map((item) => (
              <a href={item.href} aria-current={path === item.href || path.startsWith(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
            ))}
          </nav>
        </header>

        <main id="main" class="main">
          <slot />
        </main>

        <footer class="ftr" role="contentinfo">
          <span>© {new Date().getFullYear()} {site.domain}</span>
          <div>
            {site.links.map((l, i) => (
              <>
                {i > 0 && ' · '}
                <a href={l.href} target={l.href.startsWith('http') ? '_blank' : undefined} rel="noreferrer">{l.label}</a>
              </>
            ))}
          </div>
        </footer>
      </TerminalShell>
    </div>
  </body>
</html>
