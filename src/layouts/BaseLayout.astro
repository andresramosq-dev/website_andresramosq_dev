---
import '../styles/dev.css';
import TerminalShell from '../components/TerminalShell.astro';
import CommandBar from '../components/CommandBar.astro';
import { site, nav } from '../data/site';

interface Props {
	title?: string;
	description?: string;
	path?: string;
}

const { title, description, path = '/' } = Astro.props;
const pageTitle = title ? `${title} — ${site.domain}` : site.domain;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? site.description} />
    <meta name="author" content={site.name} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={`${site.domain} — RSS`} href="/rss.xml" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip" href="#main">Saltar al contenido</a>

    <div class="desk">
      <TerminalShell>
        <div class="twin__body">
          <nav class="nav" aria-label="Principal">
            {nav.map((item) => (
              <a href={item.href} aria-current={path === item.href ? 'page' : undefined}>
                {item.label}
              </a>
            ))}
          </nav>

          <details class="cmd-fold">
            <summary>navegar por comandos (/help)</summary>
            <CommandBar />
          </details>

          <main id="main" class="main">
            <slot />
          </main>
        </div>

        <footer class="ftr">
          <span>© {new Date().getFullYear()} {site.domain}</span>
          <div>
            {site.links.map((l, i) => (
              <>
                {i > 0 && ' · '}
                <a href={l.href} target={l.href.startsWith('http') ? '_blank' : undefined} rel="noreferrer">{l.label}</a>
              </>
            ))}
            {' · '}<a href="/notas">notas</a>
            {' · '}<a href="/rss.xml">rss</a>
          </div>
        </footer>
      </TerminalShell>
    </div>
  </body>
</html>
