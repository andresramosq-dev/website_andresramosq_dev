---
import '../styles/dev.css';
import { ClientRouter } from 'astro:transitions';
import SiteFooter from '../components/SiteFooter.astro';
import TerminalShell from '../components/TerminalShell.astro';
import { site, nav } from '../data/site';

interface Props {
	title?: string;
	description?: string;
	path?: string;
}

const { title, description, path = '/about' } = Astro.props;
const pageTitle = title ? `${title} — ${site.domain}` : site.domain;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? site.description} />
    <meta name="author" content={site.name} />
    <title>{pageTitle}</title>
    <ClientRouter />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>

    <div class="desk">
      <TerminalShell>
        <header class="term-hd">
          <p class="term-hd__prompt" aria-hidden="true">
            <span class="term-hd__user">{site.consoleUser}</span><span class="term-hd__at">@</span><span class="term-hd__host"
              >{site.domain}</span
            ><span class="term-hd__colon">:</span><span class="term-hd__path">~/</span><span class="term-hd__cmd"> ls</span>
          </p>
          <nav class="nav-out" aria-label="Routes">
            <p class="nav-out__total" aria-hidden="true">total {nav.length}</p>
            <ul class="ls-out nav__list">
              {nav.map((item) => {
                const current =
                  path === item.href || (item.href.length > 1 && path.startsWith(`${item.href}/`));
                return (
                  <li>
                    <a
                      href={item.href}
                      class:list={['nav__link', current && 'nav__link--current']}
                      aria-current={current ? 'page' : undefined}
                    >
                      {item.label}
                    </a>
                  </li>
                );
              })}
            </ul>
          </nav>
        </header>

        <main id="main" class="main">
          <slot />
        </main>

        <SiteFooter />
      </TerminalShell>
    </div>
  </body>
</html>
