---
import '../styles/dev.css';
import { ClientRouter } from 'astro:transitions';
import SiteFooter from '../components/SiteFooter.astro';
import TerminalShell from '../components/TerminalShell.astro';
import { site, nav } from '../data/site';

interface Props {
	title?: string;
	description?: string;
	path?: string;
}

const { title, description, path = '/about' } = Astro.props;
const pageTitle = title ? `${title} — ${site.domain}` : site.domain;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? site.description} />
    <meta name="author" content={site.name} />
    <title>{pageTitle}</title>
    <ClientRouter />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>

    <div class="desk">
      <TerminalShell>
        <header class="term-hd">
          <div class="term-hd__row">
            <span class="term-hd__ps1"
              ><span class="term-hd__user">{site.consoleUser}</span><span class="term-hd__at">@</span>{site.domain}</span
            ><span class="term-hd__dollar" aria-hidden="true">$</span>
            <span class="term-hd__cmd">ls -la</span>
            <nav class="nav" aria-label="Routes">
            {nav.map((item) => {
              const current =
                path === item.href || (item.href.length > 1 && path.startsWith(`${item.href}/`));
              return (
                <a
                  href={item.href}
                  class:list={['nav__item', 'nav__item--link', current && 'nav__item--current']}
                  aria-current={current ? 'page' : undefined}
                >
                  <span class="nav__perm" aria-hidden="true">drwxr-xr-x</span>
                  {item.label}
                </a>
              );
            })}
            </nav>
          </div>
        </header>

        <main id="main" class="main">
          <slot />
        </main>

        <SiteFooter />
      </TerminalShell>
    </div>
  </body>
</html>
