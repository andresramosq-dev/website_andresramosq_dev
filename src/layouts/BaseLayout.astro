---
import '../styles/dev.css';
import StatusBar from '../components/StatusBar.astro';
import TerminalShell from '../components/TerminalShell.astro';
import CommandBar from '../components/CommandBar.astro';
import { site, nav } from '../data/site';

interface Props {
	title?: string;
	description?: string;
	path?: string;
}

const { title, description, path = '/' } = Astro.props;
const pageTitle = title ? `${title} — ${site.name}` : site.name;
const winTitle = path === '/' ? '~/andres' : `~/andres${path}`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? site.description} />
    <meta name="author" content={site.name} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={`${site.name} — RSS`} href="/rss.xml" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip" href="#main">Saltar al contenido</a>

    <div class="desk">
      <TerminalShell title={winTitle}>
        <StatusBar />

        <nav class="tabs" aria-label="Principal">
          {nav.map((item) => (
            <a href={item.href} aria-current={path === item.href ? 'page' : undefined}>
              {item.label}
            </a>
          ))}
        </nav>

        <CommandBar />

        <main id="main" class="main">
          <slot />
        </main>

        <footer class="ftr">
          <span>© {new Date().getFullYear()} {site.name}</span>
          <div>
            {site.links.map((l, i) => (
              <>
                {i > 0 && ' · '}
                <a href={l.href} target={l.href.startsWith('http') ? '_blank' : undefined} rel="noreferrer">{l.label}</a>
              </>
            ))}
            {' · '}<a href="/rss.xml">rss</a>
          </div>
        </footer>
      </TerminalShell>
    </div>
  </body>
</html>
