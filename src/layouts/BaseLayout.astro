---
import '../styles/global.css';
import { site, nav } from '../data/site';

interface Props {
	title?: string;
	description?: string;
	currentPath?: string;
}

const {
	title = site.name,
	description = site.tagline,
	currentPath = Astro.url.pathname,
} = Astro.props;

const pageTitle = title === site.name ? title : `${title} · ${site.name}`;
const isHome = currentPath === '/';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,600;0,6..72,650;1,6..72,400&display=swap"
			rel="stylesheet"
		/>
		<title>{pageTitle}</title>
	</head>
	<body>
		<div class="site-shell">
			<header class="masthead">
				<p class="section__kicker">{site.handle}</p>
				{
					isHome ? (
						<h1 class="masthead__brand">
							<a href="/" class="masthead__brand-link">
								{site.name}
							</a>
						</h1>
					) : (
						<p class="masthead__brand">
							<a href="/" class="masthead__brand-link">
								{site.name}
							</a>
						</p>
					)
				}
				<p class="masthead__deck">{site.tagline}</p>
				<nav class="nav" aria-label="Principal">
					{
						nav.map((item) => {
							const pathOnly = item.href.split('#')[0] || '/';
							const current =
								pathOnly === '/'
									? currentPath === '/'
									: currentPath === pathOnly || currentPath.startsWith(`${pathOnly}/`);
							return (
								<a href={item.href} aria-current={current ? 'page' : undefined}>
									{item.label}
								</a>
							);
						})
					}
				</nav>
			</header>

			<main>
				<slot />
			</main>

			<footer class="site-footer">
				<span>{site.name} · cuaderno público</span>
				<span>Escrito en Markdown · Publicado con Astro</span>
			</footer>
		</div>
	</body>
</html>
