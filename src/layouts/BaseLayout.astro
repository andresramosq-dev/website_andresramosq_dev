---
import '../styles/dev.css';
import { ClientRouter } from 'astro:transitions';
import SiteFooter from '../components/SiteFooter.astro';
import TerminalShell from '../components/TerminalShell.astro';
import SpotifyFloatPanel from '../components/SpotifyFloatPanel.astro';
import { site, nav, tastes } from '../data/site';
import { spotifyPlaylistEmbedSrc } from '../lib/spotify';

interface Props {
	title?: string;
	description?: string;
	path?: string;
}

const { title, description, path = '/about' } = Astro.props;
const pageTitle = title ? `${title} — ${site.domain}` : site.domain;
const spotifyEmbedSrc = spotifyPlaylistEmbedSrc(tastes.spotify.playlistUrl);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? site.description} />
    <meta name="author" content={site.name} />
    <title>{pageTitle}</title>
    <ClientRouter />
    {spotifyEmbedSrc ? (
      <>
        <link rel="preconnect" href="https://open.spotify.com" />
        <link rel="dns-prefetch" href="https://open.spotify.com" />
      </>
    ) : null}
  </head>
  <body>
    {spotifyEmbedSrc ? (
      <>
        <SpotifyFloatPanel />
        <script src="../scripts/spotify-panel.ts"></script>
      </>
    ) : null}

    <a class="skip" href="#main">Skip to content</a>

    <div class="desk">
      <TerminalShell>
        <header class="term-hd">
          <nav class="nav" aria-label="Routes">
            {nav.map((item) => {
              const current =
                path === item.href || (item.href.length > 1 && path.startsWith(`${item.href}/`));
              return (
                <span
                  class:list={['nav__item', current && 'nav__item--current']}
                  aria-current={current ? 'page' : undefined}
                >
                  {item.label}
                </span>
              );
            })}
          </nav>
        </header>

        <main id="main" class="main">
          <slot />
        </main>

        <SiteFooter />
      </TerminalShell>
    </div>
  </body>
</html>
