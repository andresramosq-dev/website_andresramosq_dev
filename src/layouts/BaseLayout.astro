---
import '../styles/dev.css';
import { ClientRouter } from 'astro:transitions';
import TerminalShell from '../components/TerminalShell.astro';
import { site, nav, tastes } from '../data/site';
import { spotifyPlaylistUri } from '../lib/spotify';

interface Props {
	title?: string;
	description?: string;
	path?: string;
}

const { title, description, path = '/about' } = Astro.props;
const pageTitle = title ? `${title} — ${site.domain}` : site.domain;
const spotifyUri = spotifyPlaylistUri(tastes.spotify.playlistUrl);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? site.description} />
    <meta name="author" content={site.name} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <ClientRouter />
    {spotifyUri ? (
      <>
        <link rel="preconnect" href="https://open.spotify.com" />
        <link rel="dns-prefetch" href="https://open.spotify.com" />
        <link rel="preload" href="https://open.spotify.com/embed/iframe-api/v1" as="script" />
        <script is:inline>
          window.__spotifyHdrBoot = window.__spotifyHdrBoot || [];
          if (!window.onSpotifyIframeApiReady) {
            window.onSpotifyIframeApiReady = function (api) {
              window.__spotifyIframeApi = api;
              (window.__spotifyHdrBoot || []).forEach(function (fn) { fn(api); });
              window.__spotifyHdrBoot = [];
            };
          }
        </script>
        <script src="https://open.spotify.com/embed/iframe-api/v1" async></script>
      </>
    ) : null}
  </head>
  <body>
    {spotifyUri ? (
      <div class="spotify-audio-vault" transition:persist="spotify-global-player" aria-hidden="true">
        <div
          id="spotify-header-embed-host"
          class="spotify-header-sink"
          data-spotify-uri={spotifyUri}
          data-spotify-url={tastes.spotify.playlistUrl}
        ></div>
      </div>
    ) : null}

    <a class="skip" href="#main">Skip to content</a>

    <div class="desk">
      <TerminalShell>
        <header class="term-hd">
          <nav class="nav" aria-label="Routes">
            {nav.map((item) => (
              <a href={item.href} aria-current={path === item.href || path.startsWith(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
            ))}
          </nav>
        </header>

        <main id="main" class="main">
          <slot />
        </main>

        <footer class="ftr" role="contentinfo">
          <span>© {new Date().getFullYear()} {site.domain}</span>
          <div>
            {site.links.map((l, i) => (
              <>
                {i > 0 && ' · '}
                <a href={l.href} target={l.href.startsWith('http') ? '_blank' : undefined} rel="noreferrer">{l.label}</a>
              </>
            ))}
          </div>
        </footer>
      </TerminalShell>
    </div>

    <script src="../scripts/spotify-header.ts"></script>
  </body>
</html>
