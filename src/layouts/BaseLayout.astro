---
import '../styles/dev.css';
import TerminalShell from '../components/TerminalShell.astro';
import AboutNav from '../components/AboutNav.astro';
import { site } from '../data/site';
import { pathToSegment } from '../utils/segment';

interface Props {
	title?: string;
	description?: string;
	path?: string;
}

const { title, description, path = '/andres' } = Astro.props;
const pageTitle = title ? `${title} — ${site.domain}` : site.domain;
const segment = pathToSegment(path);
const isAbout = path.startsWith('/andres');
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? site.description} />
    <meta name="author" content={site.name} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip" href="#main">Saltar al contenido</a>

    <div class="desk">
      <TerminalShell segment={segment}>
        {isAbout && (
          <header class="term-hd">
            <AboutNav />
          </header>
        )}

        <main id="main" class="main">
          <slot />
        </main>

        <footer class="ftr" role="contentinfo">
          <span class="ftr__status">[exit 0]</span>
          <span>© {new Date().getFullYear()} {site.domain}</span>
          <div class="ftr__links">
            {site.links.map((l, i) => (
              <>
                {i > 0 && ' · '}
                <a href={l.href} target={l.href.startsWith('http') ? '_blank' : undefined} rel="noreferrer">{l.label}</a>
              </>
            ))}
          </div>
        </footer>
      </TerminalShell>
    </div>
  </body>
</html>
