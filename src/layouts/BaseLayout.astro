---
import '../styles/global.css';
import { site, nav } from '../data/site';

interface Props {
	title?: string;
	description?: string;
	currentPath?: string;
}

const {
	title = site.name,
	description = site.tagline,
	currentPath = Astro.url.pathname,
} = Astro.props;

const pageTitle = title === site.name ? `${site.name} · ${site.tagline}` : `${title} · ${site.name}`;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<title>{pageTitle}</title>
	</head>
	<body>
		<header class="topbar">
			<div class="shell topbar__inner">
				<a class="brand" href="/">{site.name.split(' ')[0]} <span>{site.name.split(' ')[1]}</span></a>
				<nav class="nav" aria-label="Principal">
					{
						nav.map((item) => {
							const pathOnly = item.href.split('#')[0] || '/';
							const current =
								pathOnly !== '/' &&
								(currentPath === pathOnly || currentPath.startsWith(`${pathOnly}/`));
							return (
								<a href={item.href} aria-current={current ? 'page' : undefined}>
									{item.label}
								</a>
							);
						})
					}
				</nav>
			</div>
		</header>

		<main class="shell">
			<slot />
		</main>

		<footer class="shell footer">
			<span>{site.handle}</span>
			<span>Astro</span>
		</footer>
	</body>
</html>
