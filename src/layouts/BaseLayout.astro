---
import '../styles/dev.css';
import TerminalShell from '../components/TerminalShell.astro';
import { site, nav } from '../data/site';
import { pathToSegment } from '../utils/segment';

interface Props {
	title?: string;
	description?: string;
	path?: string;
}

const { title, description, path = '/' } = Astro.props;
const pageTitle = title ? `${title} — ${site.domain}` : site.domain;
const segment = pathToSegment(path);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? site.description} />
    <meta name="author" content={site.name} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={`${site.domain} — RSS`} href="/rss.xml" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip" href="#main">Saltar al contenido</a>

    <div class="desk">
      <TerminalShell segment={segment}>
        <header class="term-hd">
          <nav class="nav" aria-label="Rutas">
            {nav.map((item) => (
              <a href={item.href} aria-current={path === item.href || (item.href !== '/' && path.startsWith(item.href)) ? 'page' : undefined}>
                {item.label}
              </a>
            ))}
          </nav>
        </header>

        <main id="main" class="main">
          <slot />
        </main>

        <footer class="ftr" role="contentinfo">
          <span>© {new Date().getFullYear()} {site.domain}</span>
          <div>
            {site.links.map((l, i) => (
              <>
                {i > 0 && ' · '}
                <a href={l.href} target={l.href.startsWith('http') ? '_blank' : undefined} rel="noreferrer">{l.label}</a>
              </>
            ))}
            {' · '}<a href="/categorias">tags</a>
            {' · '}<a href="/rss.xml">rss</a>
          </div>
        </footer>
      </TerminalShell>
    </div>
  </body>
</html>
