---
import '../styles/dev.css';
import TerminalShell from '../components/TerminalShell.astro';
import CommandBar from '../components/CommandBar.astro';
import { site, nav } from '../data/site';

interface Props {
	title?: string;
	description?: string;
	path?: string;
}

const { title, description, path = '/' } = Astro.props;
const pageTitle = title ? `${title} — ${site.domain}` : site.domain;
const segment = path === '/' ? '~' : `~${path}`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? site.description} />
    <meta name="author" content={site.name} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={`${site.domain} — RSS`} href="/rss.xml" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip" href="#main">Saltar al contenido</a>

    <div class="desk">
      <TerminalShell segment={segment}>
        <div class="term__screen">
          <nav class="nav" aria-label="Principal">
            {nav.map((item) => (
              <a href={item.href} aria-current={path === item.href ? 'page' : undefined}>
                {item.label}
              </a>
            ))}
          </nav>

          <details class="cmd-fold">
            <summary>/help — navegar por comandos</summary>
            <CommandBar />
          </details>

          <main id="main" class="main">
            <slot />
          </main>
        </div>

        <footer class="ftr">
          <span>© {new Date().getFullYear()} {site.domain}</span>
          <span>
            <a href={site.links[0].href}>github</a>
            {' · '}
            <a href={`mailto:${site.email}`}>email</a>
            {' · '}
            <a href="/rss.xml">rss</a>
          </span>
        </footer>
      </TerminalShell>
    </div>
  </body>
</html>
