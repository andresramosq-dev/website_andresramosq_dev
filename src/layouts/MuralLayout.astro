---
import '../styles/chalk-mural.css';

interface Props {
	title?: string;
	description?: string;
	/** Sin header de blog — solo el mural */
	bare?: boolean;
}

const { title, description, bare = false } = Astro.props;
const pageTitle = title ? `${title}` : 'pizarra';
const pageDescription = description ?? 'Pizarra artística de ideas';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
  </head>
  <body class="is-mural">
    <a class="skip" href="#main">Saltar</a>
    {!bare && <a class="mural-escape" href="/">← mapa</a>}
    <main id="main">
      <slot />
    </main>
  </body>
</html>
