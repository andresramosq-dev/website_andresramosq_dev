---
interface Line {
	d: string;
	dashed?: boolean;
}

interface Props {
	lines: Line[];
	class?: string;
}

const { lines, class: className } = Astro.props;
---

<svg class:list={['board-lines', className]} viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
	{
		lines.map((line) => (
			<path
				d={line.d}
				fill="none"
				stroke="currentColor"
				stroke-width="0.35"
				stroke-linecap="round"
				stroke-dasharray={line.dashed ? '1.2 1' : undefined}
				opacity="0.45"
			/>
		))
	}
</svg>
