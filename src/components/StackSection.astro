---
import Icon from './Icon.astro';
import { techTimeline } from '../data/site';

const icons = {
	code: 'code',
	layers: 'layers',
	box: 'box',
	check: 'check',
	pen: 'pen',
} as const;
---

<section class="section" id="stack" aria-labelledby="stack-title">
	<div class="section__head">
		<div class="section__icon"><Icon name="layers" size={18} /></div>
		<h2 class="section__title" id="stack-title">Stack en el tiempo</h2>
	</div>
	<p class="section__lead">Lo que fui aprendiendo en cada etapa.</p>
	<div class="stack-track">
		{
			techTimeline.map((row) => (
				<article class="stack-card">
					<div class="section__icon" style="margin-bottom: 0.55rem;">
						<Icon name={icons[row.icon as keyof typeof icons]} size={16} />
					</div>
					<p class="stack-card__period">{row.period}</p>
					<h3 class="stack-card__title">{row.title}</h3>
					<ul class="stack-card__items">
						{row.items.map((item) => (
							<li>{item}</li>
						))}
					</ul>
				</article>
			))
		}
	</div>
</section>
