---
import Icon from './Icon.astro';
import { site } from '../data/site';

const social = site.social.filter((s) => s.href && s.id !== 'cv');
---

<footer class="ftr" role="contentinfo">
	<a class="ftr__sub" href="/subscribe">subscribe</a>

	<div class="ftr__social" aria-label="Social links">
		{social.map((s) => (
			<a
				class="ftr__icon"
				href={s.href}
				aria-label={s.label}
				target={s.href.startsWith('http') ? '_blank' : undefined}
				rel={s.href.startsWith('http') ? 'noreferrer' : undefined}
			>
				<Icon name={s.icon} size={18} />
			</a>
		))}
	</div>

	<nav class="ftr__legal" aria-label="Legal">
		<a href="/privacy">privacy</a>
		<span class="ftr__dot" aria-hidden="true">·</span>
		<a href="/data">data treatment</a>
	</nav>
</footer>
