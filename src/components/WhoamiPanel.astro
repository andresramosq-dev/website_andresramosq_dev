---
import ProfilePhoto from './ProfilePhoto.astro';
import Icon from './Icon.astro';
import { site } from '../data/site';
---

<div class="whoami">
	<div class="whoami__main">
		<ProfilePhoto size="md" caption={false} />
		<div class="whoami__fields">
			<div class="whoami__row">
				<span class="whoami__key">name</span>
				<span class="whoami__val whoami__val--name">{site.name}</span>
			</div>
			<div class="whoami__row">
				<span class="whoami__key">role</span>
				<span class="whoami__val whoami__val--role">{site.role}</span>
			</div>
			<div class="whoami__row">
				<span class="whoami__key">handle</span>
				<span class="whoami__val">
					<a class="whoami__handle" href="/about">{site.handle}</a>
				</span>
			</div>
			<div class="whoami__row">
				<span class="whoami__key">location</span>
				<span class="whoami__val">{site.location}</span>
			</div>
			<div class="whoami__row whoami__row--links">
				<span class="whoami__key">social</span>
				<span class="whoami__val">
					<span class="whoami__icons">
						{site.social.map((s) => (
							<a
								href={s.href}
								title={s.label}
								aria-label={s.label}
								target={s.href.startsWith('http') ? '_blank' : undefined}
								rel={s.href.startsWith('http') ? 'noreferrer' : undefined}
							>
								<Icon name={s.icon} size={18} />
							</a>
						))}
					</span>
				</span>
			</div>
		</div>
	</div>

	<div class="tag-ideas" aria-label="Tagline style options">
		<div class="tag-ideas__item">
			<p class="tag-ideas__label">A · single box</p>
			<div class="tag-box tag-box--a">
				<span class="tag-box__text">{site.tagline}</span>
			</div>
		</div>

		<div class="tag-ideas__item">
			<p class="tag-ideas__label">B · labeled table</p>
			<div class="tag-box tag-box--b">
				<div class="tag-box__head">promise</div>
				<div class="tag-box__text">{site.tagline}</div>
			</div>
		</div>

		<div class="tag-ideas__item">
			<p class="tag-ideas__label">C · two-column row</p>
			<div class="tag-box tag-box--c">
				<div class="tag-box__key">focus</div>
				<div class="tag-box__text">{site.tagline}</div>
			</div>
		</div>

		<div class="tag-ideas__item">
			<p class="tag-ideas__label">D · rules</p>
			<div class="tag-box tag-box--d">
				<div class="tag-box__rule" aria-hidden="true"></div>
				<div class="tag-box__text">{site.tagline}</div>
				<div class="tag-box__rule" aria-hidden="true"></div>
			</div>
		</div>

		<div class="tag-ideas__item">
			<p class="tag-ideas__label">E · brackets</p>
			<div class="tag-box tag-box--e">
				<span class="tag-box__chrome">[</span>
				<span class="tag-box__text">{site.tagline}</span>
				<span class="tag-box__chrome">]</span>
			</div>
		</div>
	</div>
</div>
