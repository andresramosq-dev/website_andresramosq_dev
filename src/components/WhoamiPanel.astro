---
import ProfilePhoto from './ProfilePhoto.astro';
import Icon from './Icon.astro';
import { site } from '../data/site';
---

<div class="whoami">
	<div class="whoami__main">
		<ProfilePhoto size="md" caption={false} />
		<div class="whoami__info">
			<p class="whoami__name">{site.name}</p>
			<p class="whoami__handle">
				<a href={site.social[0].href} target="_blank" rel="noreferrer">{site.handle}</a>
			</p>
			<p class="whoami__role">{site.role}</p>
		</div>
	</div>

	<p class="whoami__tagline">
		<span class="whoami__sig">$</span> {site.tagline}
		{site.pillars.map((p) => (
			<span class="whoami__pillar">· {p}</span>
		))}
	</p>

	<div class="whoami__links">
		<span class="whoami__links-label">links</span>
		<div class="whoami__icons">
			{site.social.map((s) => (
				<a
					class="whoami__icon"
					href={s.href}
					title={s.label}
					aria-label={s.label}
					target={s.href.startsWith('http') ? '_blank' : undefined}
					rel={s.href.startsWith('http') ? 'noreferrer' : undefined}
				>
					<Icon name={s.icon} size={16} />
				</a>
			))}
		</div>
	</div>
</div>
