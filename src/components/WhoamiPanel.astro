---
import ProfilePhoto from './ProfilePhoto.astro';
import Icon from './Icon.astro';
import { site } from '../data/site';

const printText = `${site.tagline} ${site.pillars.map((p) => `· ${p}`).join(' ')}`;
---

<div class="whoami">
	<div class="whoami__main">
		<ProfilePhoto size="md" caption={false} />
		<div class="whoami__info">
			<p class="whoami__name">{site.name}</p>
			<p class="whoami__handle">
				<a href="/about">{site.handle}</a>
			</p>
			<p class="whoami__role">{site.role}</p>
			<p class="whoami__links-line">
				<span class="whoami__sig">@</span><span class="whoami__cmd"> social -all "</span>
				<span class="whoami__icons">
					{site.social.map((s) => (
						<a
							href={s.href}
							title={s.label}
							aria-label={s.label}
							target={s.href.startsWith('http') ? '_blank' : undefined}
							rel={s.href.startsWith('http') ? 'noreferrer' : undefined}
						>
							<Icon name={s.icon} size={20} />
						</a>
					))}
				</span>
				<span class="whoami__cmd">"</span>
			</p>
		</div>
	</div>

	<div class="whoami__print">
		<p class="whoami__print-line">
			<span class="whoami__sig">@</span><span class="whoami__cmd"> print \</span>
		</p>
		<p class="whoami__print-line whoami__print-line--cont">
			<span class="whoami__sig">&gt;</span> <span class="whoami__cmd">"{printText}"</span>
		</p>
	</div>
</div>
