---
import { site } from '../data/site';
import SpotifyHeaderBar from './SpotifyHeaderBar.astro';

const linkedin = site.social.find((item) => item.id === 'linkedin');
---

<div class="twin">
	<header class="twin__bar">
		<code class="twin__title">
			<span class="twin__blog">{site.consoleUser}</span><span class="twin__at">@</span><a href="/about" class="twin__host">{site.domain}</a>
			{linkedin ? (
				<a href={linkedin.href} class="twin__handle" target="_blank" rel="noreferrer">
					{site.handle}
				</a>
			) : (
				<span class="twin__handle">{site.handle}</span>
			)}{' '}
			<span class="twin__name">"Andrés Ramos Q"</span>
		</code>
		<SpotifyHeaderBar />
	</header>
	<div class="twin__body">
		<slot />
	</div>
</div>
