---
import { site } from '../data/site';
---

<div class="twin">
	<header class="twin__bar">
		<div class="twin__dots" aria-hidden="true">
			<span class="twin__dot twin__dot--close"></span>
			<span class="twin__dot twin__dot--min"></span>
			<span class="twin__dot twin__dot--max"></span>
		</div>
		<code class="twin__title">
			<span class="twin__ps1"
				><span class="twin__user">{site.consoleUser}</span><span class="twin__at">@</span>{site.domain}</span
			>
		</code>
	</header>
	<div class="twin__body">
		<slot />
	</div>
</div>
