---
import { site } from '../data/site';

interface Props {
	segment?: string;
}

const { segment = '~' } = Astro.props;
---

<div class="twin">
	<div class="twin__bar">
		<a class="twin__brand" href="/">{site.domain}</a>
		<span class="twin__sep"> — bash — </span>
		<span class="twin__path">
			<span class="user">{site.user}</span>@<span class="host">{site.domain}</span>:{segment}
		</span>
	</div>
	<div class="twin__body">
		<slot />
	</div>
</div>
