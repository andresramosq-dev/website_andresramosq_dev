---
import { site } from '../data/site';

interface Props {
	segment?: string;
}

const { segment = '~' } = Astro.props;
---

<div class="twin">
	<header class="twin__bar">
		<span class="twin__icon" aria-hidden="true">▮</span>
		<a class="twin__brand" href="/">{site.domain}</a>
		<span class="twin__sep">—</span>
		<span class="twin__app">bash</span>
		<span class="twin__path">
			<span class="user">{site.user}</span>@<span class="host">{site.domain}</span>:<span class="twin__cwd">{segment}</span>
		</span>
	</header>
	<div class="twin__body">
		<slot />
	</div>
</div>
