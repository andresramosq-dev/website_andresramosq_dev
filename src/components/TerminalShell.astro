---
import { site } from '../data/site';
---

<div class="twin">
	<header class="twin__bar">
		<code class="twin__title">
			<span class="twin__bash">bash</span><span class="twin__at">@</span><span class="twin__host">{site.domain}</span><span class="twin__slash">/</span><span class="twin__slug">{site.consoleSlug}</span>
		</code>
	</header>
	<div class="twin__body">
		<slot />
	</div>
</div>
