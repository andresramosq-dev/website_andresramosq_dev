---
interface Props {
	title?: string;
}

const { title = '~/andres — zsh' } = Astro.props;
---

<div class="twin">
	<div class="twin__bar">
		<span class="twin__dot twin__dot--r"></span>
		<span class="twin__dot twin__dot--y"></span>
		<span class="twin__dot twin__dot--g"></span>
		<span class="twin__title">{title}</span>
	</div>
	<div class="twin__body">
		<slot />
	</div>
</div>
