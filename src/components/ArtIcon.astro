---
import Icon from './Icon.astro';

interface Props {
	name: 'spark' | 'code' | 'compass' | 'pen' | 'arrow' | 'book' | 'user' | 'folder' | 'mail' | 'tag' | 'clock' | 'home';
	color: string;
	size?: 'md' | 'lg';
	class?: string;
}

const { name, color, size = 'md', class: className } = Astro.props;
const dim = size === 'lg' ? 64 : 48;
const iconSize = size === 'lg' ? 30 : 24;
---

<span
	class:list={['art-icon', `art-icon--${size}`, className]}
	style={`--icon-color: ${color}`}
>
	<Icon name={name} size={iconSize} />
</span>
