---
import { tastes } from '../data/site';
import { spotifyPlaylistEmbedSrc } from '../lib/spotify';

const playerHref = tastes.spotify.playerHref;
const linkLabel = tastes.spotify.playerLinkLabel;
const embedSrc = spotifyPlaylistEmbedSrc(tastes.spotify.playlistUrl);
---

{embedSrc ? (
	<div class="hdr-music" aria-label="Music">
		<a class="hdr-music__link" href={playerHref}>
			{linkLabel}
		</a>
		<div class="hdr-music__play-wrap">
			<span class="hdr-music__icon" aria-hidden="true" />
			<iframe
				class="hdr-music__iframe"
				title="Play playlist"
				src={embedSrc}
				width="300"
				height="80"
				allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
				loading="eager"
				referrerpolicy="strict-origin-when-cross-origin"
			/>
		</div>
		<div class="hdr-eq" data-eq aria-hidden="true">
			<span /><span /><span /><span /><span />
		</div>
	</div>
) : (
	<div class="hdr-music">
		<a class="hdr-music__link" href={playerHref}>
			{linkLabel}
		</a>
	</div>
)}

<script is:inline>
	document.querySelector('.hdr-music__play-wrap')?.addEventListener('click', function () {
		document.querySelector('[data-eq]')?.classList.add('hdr-eq--active');
	});
</script>
