---
import ArtIcon from './ArtIcon.astro';
import Icon from './Icon.astro';
import { categoryLabel, categoryColor, type CategoryId } from '../data/site';

interface Props {
	href: string;
	title: string;
	description: string;
	date: Date;
	minutes: number;
	category: CategoryId;
	icon?: 'spark' | 'code' | 'compass' | 'pen' | 'arrow' | 'book' | 'user' | 'folder' | 'mail' | 'tag' | 'clock' | 'home';
}

const { href, title, description, date, minutes, category, icon } = Astro.props;
const color = categoryColor[category];
---

<a class="post-card" href={href} style={`--card-color: ${color}`}>
	<div class="post-card__visual">
		{icon && <Icon name={icon} size={36} class="post-card__icon" />}
	</div>
	<div class="post-card__body">
		<div class="post-card__meta">
			<span class="post-card__cat">{categoryLabel[category]}</span>
			<time datetime={date.toISOString()}>
				{date.toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' })}
			</time>
			<span>{minutes} min</span>
		</div>
		<h2 class="post-card__title">{title}</h2>
		<p class="post-card__desc">{description}</p>
	</div>
</a>
