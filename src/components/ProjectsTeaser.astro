---
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => b.data.year - a.data.year);
---

<section class="section" id="proyectos" aria-labelledby="proyectos-title">
	<p class="section__kicker"># proyectos</p>
	<h2 class="section__title" id="proyectos-title">Trabajo seleccionado</h2>
	<p class="section__lead">
		Casos breves con stack y estado. <a href="/proyectos">Índice completo de proyectos</a>.
	</p>
	<div class="entry-list">
		{
			projects.map((project) => (
				<article class="entry">
					<p class="entry__meta">
						{project.data.year} · {project.data.status}
					</p>
					<h3 class="entry__title">
						{project.data.url ? (
							<a href={project.data.url}>{project.data.title}</a>
						) : (
							<a href={`/proyectos#${project.id}`}>{project.data.title}</a>
						)}
					</h3>
					<p class="entry__desc">{project.data.description}</p>
					<ul class="stack-inline">
						{project.data.stack.map((tech) => (
							<li>{tech}</li>
						))}
					</ul>
				</article>
			))
		}
	</div>
</section>
