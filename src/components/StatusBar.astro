---
import { site } from '../data/site';

const now = new Date();
const time = now.toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' });
---

<p class="status">
	<span class="status__host">{site.handle}@dev</span>
	{' · '}{time}
	{' · '}<span style="color:var(--prompt)">online</span>
</p>
