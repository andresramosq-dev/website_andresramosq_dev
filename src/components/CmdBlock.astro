---
import { site } from '../data/site';

interface Props {
	cmd: string;
	cwd?: string;
	id?: string;
	plain?: boolean;
	transcript?: boolean;
}

const { cmd, cwd = '~/', id, plain = false, transcript = false } = Astro.props;
---

<section class="cmd-block" id={id}>
	<p class="cmd-block__line">
		<span class="cmd-block__path">
			<span class="cmd-block__user">{site.consoleUser}</span><span class="cmd-block__at">@</span><span class="cmd-block__host">{site.domain}</span><span class="cmd-block__colon">:</span><span class="cmd-block__cwd">{cwd}</span>
		</span><span class="cmd-block__cmd"> {cmd}</span>
	</p>
	<div class:list={['cmd-block__out', plain && 'cmd-block__out--plain', transcript && 'cmd-block__out--transcript']}>
		<slot />
	</div>
</section>
