---
import { site } from '../data/site';

interface Props {
	cmd: string;
	id?: string;
}

const { cmd, id } = Astro.props;
---

<section class="cmd-block" id={id}>
	<p class="cmd-block__line">
		<span class="cmd-block__user">{site.user}</span>@<span class="cmd-block__host">{site.domain}</span>:<span class="cmd-block__cwd">~/andres</span><span class="cmd-block__sig">$</span>
		<span class="cmd-block__cmd">{cmd}</span>
	</p>
	<div class="cmd-block__out">
		<slot />
	</div>
</section>
