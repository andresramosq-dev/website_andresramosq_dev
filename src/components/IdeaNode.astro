---
import Icon from './Icon.astro';

interface Props {
	href?: string;
	title: string;
	subtitle?: string;
	desc?: string;
	icon?: 'spark' | 'code' | 'compass' | 'pen' | 'arrow' | 'book' | 'user' | 'folder' | 'mail' | 'tag' | 'clock' | 'home';
	color?: string;
	size?: 'lg' | 'md' | 'sm';
	frame?: 1 | 2 | 3 | 4 | 5;
	class?: string;
	style?: string;
}

const {
	href,
	title,
	subtitle,
	desc,
	icon,
	color = '#56d4dd',
	size = 'md',
	frame = 1,
	class: className,
	style,
} = Astro.props;

const Tag = href ? 'a' : 'div';

const frames: Record<number, string> = {
	1: 'M6 10c-2-4 8-8 18-6l158 4c12 2 18 8 16 18l-4 72c-2 10-10 14-22 12L22 104c-10-2-18-8-16-18l4-68c2-6 6-10 14-10Z',
	2: 'M12 6l172 8c8 0 14 6 12 16l-8 78c-2 12-10 16-20 14L18 108c-12-2-16-10-14-20l10-74c2-8 8-12 18-8Z',
	3: 'M8 14l184-6c6 2 10 8 8 20l-6 70c0 12-8 18-18 16L14 106c-10-2-14-12-12-22l8-62c2-6 6-10 14-8Z',
	4: 'M10 8c4-6 160-4 172 0 10 4 16 12 14 24l-6 68c-2 10-12 16-24 14L20 108c-12-2-18-10-16-22l8-70c2-8 8-12 18-8Z',
	5: 'M14 12l166 2c10 2 16 10 14 22l-10 64c-2 12-12 16-22 14L16 106c-10-2-16-12-14-24l12-58c2-8 10-12 20-12Z',
};
---

<Tag
	href={href}
	class:list={['node', `node--${size}`, className]}
	style={`--node-color: ${color}; ${style ?? ''}`}
>
	<svg class="node__frame" viewBox="0 0 200 120" preserveAspectRatio="none" aria-hidden="true">
		<path d={frames[frame]} fill="var(--node-color)" opacity="0.9" />
		<path d={frames[frame]} fill="none" stroke="#0a0c10" stroke-width="2.2" opacity="0.4" />
	</svg>
	<div class="node__body">
		{icon && (
			<span class="node__icon">
				<Icon name={icon} size={size === 'lg' ? 30 : size === 'sm' ? 18 : 24} />
			</span>
		)}
		<span class="node__title">{title}</span>
		{subtitle && <span class="node__sub">{subtitle}</span>}
		{desc && <span class="node__desc">{desc}</span>}
	</div>
</Tag>
