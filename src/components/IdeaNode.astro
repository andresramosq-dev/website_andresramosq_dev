---
import Icon from './Icon.astro';

interface Props {
	href?: string;
	title: string;
	subtitle?: string;
	icon?: 'spark' | 'code' | 'compass' | 'pen' | 'arrow' | 'book' | 'user' | 'folder' | 'mail' | 'tag' | 'clock' | 'home';
	color?: string;
	size?: 'lg' | 'md' | 'sm';
	class?: string;
	style?: string;
}

const {
	href,
	title,
	subtitle,
	icon,
	color = '#56d4dd',
	size = 'md',
	class: className,
	style,
} = Astro.props;

const Tag = href ? 'a' : 'div';
---

<Tag
	href={href}
	class:list={['node', `node--${size}`, className]}
	style={`--node-color: ${color}; ${style ?? ''}`}
>
	<svg class="node__shape" viewBox="0 0 220 130" aria-hidden="true">
		<path
			d="M12 18 L200 10 Q212 10 210 28 L206 108 Q204 122 188 120 L18 126 Q6 124 8 108 L12 28 Q14 14 28 16 Z"
			fill="var(--node-color)"
			opacity="0.92"
		/>
		<path
			d="M12 18 L200 10 Q212 10 210 28 L206 108 Q204 122 188 120 L18 126 Q6 124 8 108 L12 28 Q14 14 28 16 Z"
			fill="none"
			stroke="#0d1117"
			stroke-width="2.5"
			opacity="0.35"
		/>
	</svg>
	<div class="node__body">
		{icon && (
			<span class="node__icon">
				<Icon name={icon} size={size === 'lg' ? 28 : size === 'sm' ? 18 : 22} />
			</span>
		)}
		<span class="node__title">{title}</span>
		{subtitle && <span class="node__sub">{subtitle}</span>}
	</div>
</Tag>
