---
import Icon from './Icon.astro';
import { categoryLabel, type CategoryId } from '../data/site';

interface Props {
	href: string;
	title: string;
	description: string;
	date: Date;
	minutes: number;
	category: CategoryId;
	icon?: 'spark' | 'code' | 'compass' | 'pen' | 'arrow' | 'book' | 'user' | 'folder' | 'mail' | 'tag' | 'clock' | 'home';
}

const { href, title, description, date, minutes, category, icon } = Astro.props;
---

<li class="post-entry">
	<a href={href}>
		{icon && (
			<span class="post-entry__icon">
				<Icon name={icon} size={20} />
			</span>
		)}
		<div>
			<h2 class="post-entry__title">{title}</h2>
			<p class="post-entry__desc">{description}</p>
		</div>
		<span class="post-entry__meta">
			{categoryLabel[category]} · {date.toLocaleDateString('es-ES', { month: 'short', year: 'numeric' })} · {minutes} min
		</span>
	</a>
</li>
