---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<section class="section" id="blog" aria-labelledby="blog-title">
	<p class="section__kicker"># blog</p>
	<h2 class="section__title" id="blog-title">Notas recientes</h2>
	<p class="section__lead">
		Artículos en Markdown. <a href="/blog">Ver todo el blog</a> · el primero explica cómo se publica una nota.
	</p>
	<div class="entry-list">
		{
			posts.map((post) => (
				<article class="entry">
					<p class="entry__meta">
						{post.data.section} ·{' '}
						{post.data.pubDate.toLocaleDateString('es-ES', {
							year: 'numeric',
							month: 'short',
							day: 'numeric',
						})}
					</p>
					<h3 class="entry__title">
						<a href={`/blog/${post.id}`}>{post.data.title}</a>
					</h3>
					<p class="entry__desc">{post.data.description}</p>
				</article>
			))
		}
	</div>
</section>
