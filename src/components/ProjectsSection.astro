---
import { getCollection } from 'astro:content';
import Icon from './Icon.astro';

const projects = (await getCollection('projects')).sort((a, b) => b.data.year - a.data.year).slice(0, 3);
---

<section class="section" id="proyectos" aria-labelledby="proyectos-title">
	<div class="section__head">
		<div class="section__icon"><Icon name="folder" size={18} /></div>
		<h2 class="section__title" id="proyectos-title">Proyectos</h2>
	</div>
	<p class="section__lead">Selección corta de trabajo reciente.</p>
	<div class="card-grid">
		{
			projects.map((project) => (
				<a class="card" href={`/proyectos#${project.id}`}>
					<div class="card__mark">
						<Icon name="box" size={18} />
					</div>
					<p class="card__meta">
						{project.data.year} · {project.data.status}
					</p>
					<h3 class="card__title">{project.data.title}</h3>
					<p class="card__text">{project.data.description}</p>
					<div class="card__foot">
						{project.data.stack.slice(0, 3).map((tech) => (
							<span class="chip">{tech}</span>
						))}
					</div>
				</a>
			))
		}
	</div>
	<a class="section-link" href="/proyectos">
		Ver todos
		<Icon name="arrow" size={16} />
	</a>
</section>
