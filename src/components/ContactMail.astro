---
import { site } from '../data/site';

const accessKey =
	import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY?.trim() || site.web3formsAccessKey;
---

<div class="contact-mail">
	<form
		class="contact-mail__form"
		action="https://api.web3forms.com/submit"
		method="POST"
		data-contact-form
	>
		<input type="hidden" name="access_key" value={accessKey} />
		<input type="hidden" name="from_name" value="andresramosq.dev contact" />
		<input type="checkbox" name="botcheck" class="contact-mail__hp" tabindex="-1" autocomplete="off" aria-hidden="true" />

		<label class="contact-mail__row">
			<span class="contact-mail__key">from</span>
			<input
				class="contact-mail__input"
				type="email"
				name="email"
				required
				autocomplete="email"
				placeholder="you@example.com"
				aria-label="Your email"
			/>
		</label>
		<label class="contact-mail__row">
			<span class="contact-mail__key">subject</span>
			<input
				class="contact-mail__input"
				type="text"
				name="subject"
				required
				maxlength={200}
				placeholder="What is it about?"
				aria-label="Subject"
			/>
		</label>
		<label class="contact-mail__row contact-mail__row--body">
			<span class="contact-mail__key">message</span>
			<textarea
				class="contact-mail__input contact-mail__input--area"
				name="message"
				required
				rows={6}
				placeholder="Your message…"
				aria-label="Message"
			/>
		</label>
		<div class="contact-mail__actions">
			<button class="contact-mail__send" type="submit">
				send
			</button>
			<p class="contact-mail__status" data-contact-status hidden aria-live="polite" />
		</div>
	</form>
</div>

<script>
	function bindContactForm(form: HTMLFormElement) {
		if (form.dataset.bound === '1') return;
		form.dataset.bound = '1';

		const status = form.querySelector<HTMLElement>('[data-contact-status]');
		const submit = form.querySelector<HTMLButtonElement>('.contact-mail__send');

		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			if (!submit) return;

			submit.disabled = true;
			if (status) {
				status.hidden = false;
				status.textContent = 'sending…';
				status.dataset.state = 'pending';
			}

			try {
				const payload = Object.fromEntries(new FormData(form).entries());
				const res = await fetch(form.action, {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
						Accept: 'application/json',
					},
					body: JSON.stringify(payload),
				});
				const data = (await res.json()) as { success?: boolean; message?: string };

				if (data.success) {
					form.reset();
					if (status) {
						status.textContent = 'sent — I will reply to your email.';
						status.dataset.state = 'ok';
					}
				} else {
					throw new Error(data.message ?? 'send failed');
				}
			} catch {
				if (status) {
					status.textContent = 'could not send. Try again or email andresramosq.dev@gmail.com.';
					status.dataset.state = 'error';
				}
			} finally {
				submit.disabled = false;
			}
		});
	}

	document.querySelectorAll<HTMLFormElement>('[data-contact-form]').forEach(bindContactForm);
	document.addEventListener('astro:page-load', () => {
		document.querySelectorAll<HTMLFormElement>('[data-contact-form]').forEach(bindContactForm);
	});
</script>
