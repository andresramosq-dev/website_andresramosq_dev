---
export interface FeedItem {
	href: string;
	title: string;
	meta?: string;
}

interface Props {
	items: FeedItem[];
	dir?: boolean;
}

const { items, dir = false } = Astro.props;
---

<ul class="feed">
	{
		items.map((item) => (
			<li>
				<a href={item.href}>
					<span class="feed__perm">{dir ? 'drwxr-xr-x' : '-rw-r--r--'}</span>
					<span class="feed__title">{item.title}</span>
					{item.meta && <span class="feed__meta">{item.meta}</span>}
				</a>
			</li>
		))
	}
</ul>
