---
import { stack } from '../data/site';
---

<div class="console-doc console-doc--stack">
	{stack.groups.map((group) => (
		<p class="stack-line">
			<span class="stack-line__key">{group.label}</span>
			<span class="stack-line__val">
				{group.items.map((item) => (
					<span class="stack-tag">
						<span class="stack-tag__hash">#</span>
						{item}
					</span>
				))}
			</span>
		</p>
	))}
</div>
