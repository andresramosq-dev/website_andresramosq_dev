---
import Icon from './Icon.astro';
import { site } from '../data/site';
---

<section class="section" id="sobre" aria-labelledby="sobre-title">
	<div class="section__head">
		<div class="section__icon"><Icon name="user" size={18} /></div>
		<h2 class="section__title" id="sobre-title">Sobre mí</h2>
	</div>
	<div class="about-grid">
		<div class="panel">
			<p class="about-text">{site.bio}</p>
		</div>
		<div class="panel">
			<ul class="meta-list">
				<li>
					<span>Rol</span>
					<strong>{site.role}</strong>
				</li>
				<li>
					<span>Ubicación</span>
					<strong>{site.location}</strong>
				</li>
				<li>
					<span>Contacto</span>
					<strong>
						{site.links.map((link, i) => (
							<span>
								{i > 0 ? ' · ' : ''}
								<a href={link.href}>{link.label}</a>
							</span>
						))}
					</strong>
				</li>
			</ul>
		</div>
	</div>
</section>
