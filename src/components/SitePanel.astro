---
import { site } from '../data/site';
import BioTag from './BioTag.astro';

function joinItems(items: readonly string[]) {
	return items.map((item, i) => ({
		item,
		sep: i === 0 ? '' : i === items.length - 1 ? ' and ' : ', ',
	}));
}

interface Props {
	part: 'intro' | 'meta';
}

const { part } = Astro.props;
const { aboutSite } = site;
---

{part === 'intro' && (
	<div class="site-about">
		<p class="site-about__lead">
			<span class="site-about__desc">{aboutSite.leadBefore}</span>{' '}
			<span class="site-about__domain site-about__domain--text">{site.domain}</span>
			<span class="site-about__desc">{aboutSite.leadAfter}</span>
		</p>
		{aboutSite.body.map((line) => (
			<p class="site-about__out">{line}</p>
		))}
	</div>
)}

{part === 'meta' && (
	<div class="site-about">
		<div class="tag-box tag-box--c site-about__build">
			<div class="tag-box__key">build</div>
			<div class="tag-box__text">
				<span class="site-about__out-inline">{aboutSite.builtBefore}</span>{' '}
				{joinItems(aboutSite.builtWith).map(({ item, sep }) => (
					<>
						{sep}<BioTag label={item} />
					</>
				))}
				<span class="site-about__out-inline">{aboutSite.builtMid}</span>{' '}
				{joinItems(aboutSite.builtAlso).map(({ item, sep }) => (
					<>
						{sep}<BioTag label={item} />
					</>
				))}
				<span class="site-about__out-inline">{aboutSite.builtAfter}</span>
			</div>
		</div>
		<p class="site-about__idea">{aboutSite.design}</p>
		<div class="tag-box tag-box--c tag-box--solo">
			<div class="tag-box__text">{aboutSite.language}</div>
		</div>
	</div>
)}
