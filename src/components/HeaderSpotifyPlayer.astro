---
import { tastes } from '../data/site';
import { spotifyPlaylistEmbedSrc } from '../lib/spotify';

const embedSrc = spotifyPlaylistEmbedSrc(tastes.spotify.playlistUrl);
const label = tastes.spotify.playlistLabel ?? 'playlist';
---

{embedSrc ? (
	<div class="hdr-player">
		<iframe
			class="hdr-player__frame"
			title={`Spotify: ${label}`}
			src={embedSrc}
			width="100%"
			height="80"
			allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
			loading="lazy"
			referrerpolicy="strict-origin-when-cross-origin"
		/>
	</div>
) : null}
