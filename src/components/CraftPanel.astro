---
import { craft } from '../data/site';
---

<div class="kv-sheet">
	<section class="kv-sheet__block">
		<h3 class="kv-sheet__heading">philosophy</h3>
		<dl class="kv-sheet__list">
			{craft.principles.map((row) => (
				<div class="kv-sheet__row">
					<dt>{row.key}</dt>
					<dd>{row.value}</dd>
				</div>
			))}
		</dl>
	</section>

	<section class="kv-sheet__block">
		<h3 class="kv-sheet__heading">stack</h3>
		<dl class="kv-sheet__list">
			{craft.skills.map((row) => (
				<div class="kv-sheet__row">
					<dt>{row.area}</dt>
					<dd class="kv-sheet__stack">{row.items}</dd>
				</div>
			))}
		</dl>
	</section>
</div>
