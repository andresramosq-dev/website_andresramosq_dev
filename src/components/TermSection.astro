---
interface Props {
	cmd: string;
	link?: { href: string; label: string };
}

const { cmd, link } = Astro.props;
---

<section class="sec">
	<div class="sec__head">
		<h2 class="sec__title">
			<span class="term__prompt">$ </span>{cmd}
		</h2>
		{link && <a class="sec__link" href={link.href}>{link.label}</a>}
	</div>
	<slot />
</section>
