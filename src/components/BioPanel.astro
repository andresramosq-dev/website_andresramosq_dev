---
import { site } from '../data/site';
import BioTag from './BioTag.astro';
import BioKeyword from './BioKeyword.astro';

function joinItems(items: readonly string[]) {
	return items.map((item, i) => ({
		item,
		sep: i === 0 ? '' : i === items.length - 1 ? ', and ' : ', ',
	}));
}
---

<div class="bio">
	<p class="bio__out">
		Senior software developer with 4+ years in backend work —
		{' '}
		{joinItems(site.bioStack).map(({ item, sep }) => (
			<>
				{sep}<BioTag label={item} />
			</>
		))}.
	</p>
	<p class="bio__out">
		I have built software at an insurance fintech: payment gateways, SOAT product sales, and keeping codebases healthy over time.
	</p>
	<p class="bio__out">
		I have also built systems from scratch — including a VCC platform with IAM, call handling, CRM, and more.
	</p>
	<p class="bio__out">
		Passionate about{' '}
		{joinItems(site.bioValues).map(({ item, sep }) => (
			<>
				{sep}<BioKeyword label={item} />
			</>
		))}.
	</p>
</div>
