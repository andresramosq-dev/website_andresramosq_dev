---
import { site } from '../data/site';
import BioTag from './BioTag.astro';
import BioKeyword from './BioKeyword.astro';

function joinItems(items: readonly string[]) {
	return items.map((item, i) => ({
		item,
		sep: i === 0 ? '' : i === items.length - 1 ? ', and ' : ', ',
	}));
}
---

<div class="bio">
	<p class="bio__lead">
		<span class="bio__lead-text">{site.bioLead}</span>
		<span class="bio__sep"> — </span>
		<span class="bio__stack">
			{joinItems(site.bioStack).map(({ item, sep }) => (
				<>
					{sep}<BioTag label={item} />
				</>
			))}
		</span>.
	</p>

	<div class="bio__body">
		{site.bioExperience.map((line) => (
			<p class="bio__out">{line}</p>
		))}
	</div>

	<p class="bio__close">
		I care about{' '}
		{joinItems(site.bioValues).map(({ item, sep }) => (
			<>
				{sep}<BioKeyword label={item} />
			</>
		))}.
	</p>

	<p class="bio__quote">
		<span class="bio__quote-prefix">&gt;</span> {site.bioQuote}
	</p>
</div>
