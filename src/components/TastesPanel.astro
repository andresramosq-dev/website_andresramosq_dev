---
import { tastes } from '../data/site';

function spotifyPlaylistEmbed(url: string | null) {
	if (!url) return null;
	const match = url.match(/playlist\/([a-zA-Z0-9]+)(?:\?|$)/);
	if (!match) return null;
	return `https://open.spotify.com/embed/playlist/${match[1]}?utm_source=generator&theme=0`;
}

const playlistEmbed = spotifyPlaylistEmbed(tastes.spotify.playlistUrl);
const playlistLabel = tastes.spotify.playlistLabel ?? 'playlist';
---

<div class="tastes-out">
	<p class="tastes-out__banner">{tastes.lead}</p>

	<section class="tastes-out__block" aria-labelledby="tastes-figures">
		<h3 class="tastes-out__head" id="tastes-figures">figures</h3>
		<ul class="tastes-out__list">
			{tastes.figures.map((figure) => (
				<li>
					<span class="tastes-out__strong">{figure.name}</span>
					<span class="tastes-out__dim"> — {figure.text}</span>
				</li>
			))}
		</ul>
	</section>

	<section class="tastes-out__block" aria-labelledby="tastes-movies">
		<h3 class="tastes-out__head" id="tastes-movies">movies</h3>
		<table class="term-table">
			<thead>
				<tr>
					<th scope="col">#</th>
					<th scope="col">title</th>
					<th scope="col">year</th>
				</tr>
			</thead>
			<tbody>
				{tastes.movies.map((movie) => (
					<tr>
						<td class="term-table__rank">{String(movie.rank).padStart(2, '0')}</td>
						<td>{movie.title}</td>
						<td class="term-table__muted">{movie.year}</td>
					</tr>
				))}
			</tbody>
		</table>
	</section>

	<section class="tastes-out__block" aria-labelledby="tastes-series">
		<h3 class="tastes-out__head" id="tastes-series">series</h3>
		<div class="stack-group__chips stack-group__chips--column">
			{tastes.series.map((title) => (
				<span class="stack-chip">
					<span class="stack-chip__hash">#</span>
					{title}
				</span>
			))}
		</div>
	</section>

	<section class="tastes-out__block tastes-out__block--music" aria-labelledby="tastes-music">
		<h3 class="tastes-out__head" id="tastes-music">music</h3>
		{playlistEmbed ? (
			<>
				<p class="tastes-out__stream">
					<span class="tastes-out__prompt">stream</span>
					<span class="tastes-out__eq">=</span>
					<span class="tastes-out__strong">{playlistLabel}</span>
				</p>
				<div class="spotify-console" aria-label="Spotify playlist player">
					<div class="spotify-console__titlebar">
						<span class="spotify-console__lights" aria-hidden="true">
							<span class="spotify-console__light spotify-console__light--on" />
						</span>
						<span class="spotify-console__title">spotify — {playlistLabel}</span>
						<span class="spotify-console__badge">live</span>
					</div>
					<div class="spotify-console__body">
						<iframe
							title={`Spotify playlist: ${playlistLabel}`}
							src={playlistEmbed}
							width="100%"
							height="380"
							allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
							loading="lazy"
							referrerpolicy="strict-origin-when-cross-origin"
						/>
					</div>
				</div>
			</>
		) : (
			<p class="tastes-out__dim">playlist not configured.</p>
		)}
	</section>
</div>
