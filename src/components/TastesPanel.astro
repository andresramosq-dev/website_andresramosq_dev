---
import { tastes } from '../data/site';

function spotifyPlaylistEmbed(url: string | null) {
	if (!url) return null;
	const match = url.match(/playlist\/([a-zA-Z0-9]+)/);
	if (!match) return null;
	return `https://open.spotify.com/embed/playlist/${match[1]}?utm_source=generator&theme=0`;
}

const playlistEmbed = spotifyPlaylistEmbed(tastes.spotify.playlistUrl);
---

<div class="console-doc tastes-doc">
	<p class="console-doc__line console-doc__line--open">{tastes.lead}</p>

	<p class="tastes-doc__cmd">
		<span class="tastes-doc__sig">$</span> cat figures.txt
	</p>
	{tastes.figures.map((figure) => (
		<p class="console-doc__line">
			<span class="tastes-doc__key">{figure.name}</span>
			<span class="tastes-doc__sep"> — </span>
			{figure.text}
		</p>
	))}

	<p class="tastes-doc__cmd">
		<span class="tastes-doc__sig">$</span> cat movies.txt
	</p>
	{tastes.movies.map((movie) => (
		<p class="console-doc__line tastes-doc__movie">
			<span class="tastes-doc__rank">{String(movie.rank).padStart(2, '0')}</span>
			<span class="tastes-doc__movie-title">{movie.title}</span>
			<span class="tastes-doc__movie-year">{movie.year}</span>
		</p>
	))}

	<p class="tastes-doc__cmd">
		<span class="tastes-doc__sig">$</span> cat series.txt
	</p>
	<p class="console-doc__line tastes-doc__series">
		{tastes.series.map((title) => (
			<span class="taste-chip">{title}</span>
		))}
	</p>

	<p class="tastes-doc__cmd">
		<span class="tastes-doc__sig">$</span> spotify --playlist
	</p>
	{playlistEmbed ? (
		<div class="tastes-doc__spotify">
			<iframe
				title="Spotify playlist"
				src={playlistEmbed}
				width="100%"
				height="352"
				allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
				loading="lazy"
				referrerpolicy="strict-origin-when-cross-origin"
			/>
		</div>
	) : (
		<>
			<p class="console-doc__line">
				<a class="tastes-doc__link" href={tastes.spotify.profileUrl} target="_blank" rel="noreferrer">
					{tastes.spotify.profileUrl.replace('https://', '')}
				</a>
			</p>
			<p class="console-doc__line tastes-doc__hint">
				Yes — Spotify lets you embed a public playlist. Send me the playlist link (Share → Copy link) and it shows up here as a player.
			</p>
		</>
	)}
</div>
