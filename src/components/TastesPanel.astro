---
import { tastes } from '../data/site';

function spotifyPlaylistEmbed(url: string | null) {
	if (!url) return null;
	const match = url.match(/playlist\/([a-zA-Z0-9]+)(?:\?|$)/);
	if (!match) return null;
	return `https://open.spotify.com/embed/playlist/${match[1]}?utm_source=generator&theme=0`;
}

const playlistEmbed = spotifyPlaylistEmbed(tastes.spotify.playlistUrl);
const { spotify } = tastes;
---

<div class="favorites">
	<p class="favorites__lead">{tastes.lead}</p>

	<section class="fav-pane">
		<h3 class="fav-pane__title">influential figures</h3>
		<ul class="fav-pane__figures">
			{tastes.figures.map((figure) => (
				<li>
					<span class="fav-pane__name">{figure.name}</span>
					<span class="fav-pane__sep"> — </span>
					<span>{figure.text}</span>
				</li>
			))}
		</ul>
	</section>

	<section class="fav-pane">
		<h3 class="fav-pane__title">top movies</h3>
		<ul class="fav-pane__movies">
			{tastes.movies.map((movie) => (
				<li>
					<span class="fav-pane__rank">{movie.rank}</span>
					<span class="fav-pane__movie">{movie.title}</span>
					<span class="fav-pane__year">{movie.year}</span>
				</li>
			))}
		</ul>
	</section>

	<section class="fav-pane">
		<h3 class="fav-pane__title">influential series</h3>
		<div class="fav-pane__chips">
			{tastes.series.map((title) => (
				<span class="fav-chip">{title}</span>
			))}
		</div>
	</section>

	<section class="fav-pane fav-pane--spotify">
		<h3 class="fav-pane__title">music</h3>
		<p class="fav-pane__note">
			Spotify does not allow playing a whole public profile inside a website — only a <strong>public playlist</strong> with its own link.
		</p>
		<p class="fav-pane__actions">
			<a class="fav-pane__btn" href={spotify.profileUrl} target="_blank" rel="noreferrer">
				Open my Spotify profile
			</a>
		</p>
		{playlistEmbed ? (
			<div class="fav-spotify-player">
				<p class="fav-spotify-player__label">playlist</p>
				<iframe
					title="Spotify playlist"
					src={playlistEmbed}
					width="100%"
					height="352"
					allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
					loading="lazy"
					referrerpolicy="strict-origin-when-cross-origin"
				/>
			</div>
		) : (
			<p class="fav-pane__hint">
				To play music here: open a playlist on your profile → Share → Copy link → send it to me and I embed the player on this page.
			</p>
		)}
	</section>
</div>
