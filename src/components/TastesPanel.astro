---
import { tastes } from '../data/site';
import SpotifyEmbed from './SpotifyEmbed.astro';
---

<div class="console-doc tastes">
	<section class="tastes__section">
		<p class="stack-group__label">figures</p>
		<ul class="tastes__lines">
			{tastes.figures.map((figure) => (
				<li>
					<span class="tastes__name">{figure.name}</span>
					<span class="tastes__muted"> — {figure.text}</span>
				</li>
			))}
		</ul>
	</section>

	<section class="tastes__section">
		<p class="stack-group__label">movies</p>
		<table class="term-table">
			<thead>
				<tr>
					<th scope="col">#</th>
					<th scope="col">title</th>
					<th scope="col">year</th>
				</tr>
			</thead>
			<tbody>
				{tastes.movies.map((movie) => (
					<tr>
						<td class="term-table__rank">{movie.rank}</td>
						<td>{movie.title}</td>
						<td class="term-table__muted">{movie.year}</td>
					</tr>
				))}
			</tbody>
		</table>
	</section>

	<section class="tastes__section">
		<p class="stack-group__label">series</p>
		<ul class="tastes__lines">
			{tastes.series.map((title) => (
				<li>{title}</li>
			))}
		</ul>
	</section>

	<section class="tastes__section" id="music">
		<p class="stack-group__label">music</p>
		<p class="console-doc__line tastes__music-line">
			<span class="tastes__name">{tastes.spotify.playlistLabel}</span>
		</p>
		<SpotifyEmbed variant="panel" />
	</section>
</div>
