---
import { site } from '../data/site';

interface Props {
	command?: string;
	slug?: string;
}

const { command = 'about', slug = 'andres-ramos' } = Astro.props;
---

<h1 class="console-title">
	<span class="console-title__prompt">
		<span class="console-title__conn" aria-hidden="true">╭─</span>
		<span class="console-title__user">{site.user}</span><span class="console-title__at">@</span><span class="console-title__host">{site.domain}</span><span class="console-title__sep">:</span><span class="console-title__cwd">~/about</span>
	</span>
	<span class="console-title__cmd">
		<span class="console-title__conn" aria-hidden="true">╰─</span>
		<span class="console-title__bin">{command}</span>
		<span class="console-title__page"> -{slug}</span>
	</span>
</h1>
