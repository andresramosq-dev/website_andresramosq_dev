---
import { site } from '../data/site';

interface Props {
	command?: string;
}

const { command = 'about' } = Astro.props;
---

<h1 class="console-title">
	<span class="console-title__line">
		<span class="console-title__user">{site.consoleUser}</span><span class="console-title__at">@</span><span class="console-title__host">{site.domain}</span><span class="console-title__sig"> @</span><span class="console-title__command"> {command}</span><span class="console-title__print"> print</span>
	</span>
</h1>
