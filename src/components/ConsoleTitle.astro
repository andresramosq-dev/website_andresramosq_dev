---
import { site } from '../data/site';

interface Props {
	title?: string;
}

const { title = site.name } = Astro.props;
---

<header class="console-title">
	<p class="console-title__prompt">
		<span class="console-title__user">{site.consoleUser}</span><span class="console-title__at">@</span><span class="console-title__host">{site.domain}</span><span class="console-title__colon">:</span><span class="console-title__path">~/</span><span class="console-title__sig"> @</span><span class="console-title__cmd"> about about -title</span>
	</p>
	<h1 class="console-title__headline">{title}</h1>
</header>
