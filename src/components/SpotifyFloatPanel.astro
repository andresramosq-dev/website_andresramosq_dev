---
import SpotifyEmbed from './SpotifyEmbed.astro';
---

<div
	id="spotify-panel-root"
	class="spotify-float"
	transition:persist="spotify-panel"
	data-open="false"
	aria-hidden="true"
>
	<div class="spotify-float__panel" role="dialog" aria-label="Music player">
		<div class="spotify-float__bar">
			<div class="spotify-float__titles">
				<p class="spotify-float__cover">I&apos;m programming cover</p>
				<p class="spotify-float__track">I&apos;m programming</p>
			</div>
			<button
				type="button"
				class="spotify-float__close"
				data-spotify-panel-close
				aria-label="Close player"
			>
				×
			</button>
		</div>
		<div class="spotify-float__body">
			<p class="spotify-float__notice" role="note">
				<span class="spotify-float__notice-label">note</span>
				<span class="spotify-float__notice-text">
					You need an active Spotify session in this browser to play music here.
					<span class="spotify-float__notice-line">
						Log in at
						<a href="https://open.spotify.com" target="_blank" rel="noreferrer">open.spotify.com</a>
						if playback is limited to previews.
					</span>
				</span>
			</p>
			<div class="spotify-float__player cmd-block__out">
				<SpotifyEmbed />
			</div>
		</div>
	</div>
</div>
