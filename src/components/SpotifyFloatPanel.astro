---
import SpotifyEmbed from './SpotifyEmbed.astro';
import { tastes } from '../data/site';

const playlistUrl = tastes.spotify.playlistUrl;
---

<div
	id="spotify-panel-root"
	class="spotify-float"
	transition:persist="spotify-panel"
	data-open="false"
	aria-hidden="true"
>
	<div class="spotify-float__panel" role="dialog" aria-label="Music player">
		<header class="spotify-float__bar">
			<span class="spotify-float__title">I&apos;m programming</span>
			<button
				type="button"
				class="spotify-float__close"
				data-spotify-panel-close
				aria-label="Close player"
			>
				×
			</button>
		</header>
		<div class="spotify-float__body">
			<p class="spotify-float__hint">
				Log in to{' '}
				<a class="spotify-float__link" href="https://open.spotify.com" target="_blank" rel="noreferrer">
					Spotify
				</a>
				{' '}in this browser — Premium plays the full playlist; otherwise you only get previews.
				{playlistUrl ? (
					<>
						{' '}
						<a class="spotify-float__link" href={playlistUrl} target="_blank" rel="noreferrer">
							Open playlist
						</a>
					</>
				) : null}
			</p>
			<SpotifyEmbed />
		</div>
	</div>
</div>
