---
import { techTimeline } from '../data/site';
---

<section class="section" id="tecnologias" aria-labelledby="tech-title">
	<p class="section__kicker"># experiencia</p>
	<h2 class="section__title" id="tech-title">Línea de tiempo técnica</h2>
	<p class="section__lead">
		Tecnologías aprendidas por etapas de trabajo. Sin badges: solo periodos, herramientas y una nota.
	</p>
	<div class="timeline">
		{
			techTimeline.map((row) => (
				<div class="timeline__row">
					<div class="timeline__period">{row.period}</div>
					<div>
						<h3 class="timeline__title">{row.title}</h3>
						<ul class="timeline__items">
							{row.items.map((item) => (
								<li>{item}</li>
							))}
						</ul>
						<p class="timeline__note">{row.note}</p>
					</div>
				</div>
			))
		}
	</div>
</section>
