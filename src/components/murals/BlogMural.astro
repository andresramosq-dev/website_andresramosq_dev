---
import { site } from '../data/site';

interface Props {
	posts: { id: string; title: string; category: string }[];
}

const { posts } = Astro.props;

const notePositions = [
	{ x: 180, y: 200, rot: -4, color: '#56d4dd' },
	{ x: 520, y: 160, rot: 3, color: '#ff7b72' },
	{ x: 900, y: 220, rot: -2, color: '#bc8cff' },
	{ x: 350, y: 480, rot: 2, color: '#e3b341' },
	{ x: 780, y: 520, rot: -3, color: '#56d4dd' },
];
---

<svg
	class="mural-svg"
	viewBox="0 0 1200 800"
	xmlns="http://www.w3.org/2000/svg"
	role="img"
	aria-label="Muro de escritos dibujados a tiza"
>
	<rect width="1200" height="800" fill="#2a2f36" />

	<!-- textura polvo -->
	<g fill="#ebe6dc" opacity="0.06">
		<circle cx="80" cy="60" r="1.5" /><circle cx="300" cy="120" r="1" />
		<circle cx="950" cy="80" r="1.3" /><circle cx="1100" cy="400" r="1.1" />
		<circle cx="150" cy="650" r="1.2" /><circle cx="700" cy="750" r="1" />
	</g>

	<!-- marco dibujado a mano -->
	<path
		class="chalk-stroke"
		d="M25 30c8-12 1150-18 1160 8 6 16 4 740-8 768-10 22-1148 26-1168-4-8-12-6-750 8-774Z"
		stroke-width="2.5"
		opacity="0.2"
		stroke-dasharray="10 7"
	/>

	<!-- estante dibujado -->
	<g class="chalk-stroke" stroke-width="3" opacity="0.45">
		<path d="M100 600c200-8 400-4 600 0s400 4 500 0" />
		<path d="M100 600v12M700 600v12M1100 600v12" />
	</g>

	<!-- cuaderno abierto grande (decoración) -->
	<g transform="translate(420 580)" opacity="0.35">
		<path class="chalk-stroke" stroke-width="2.5" d="M0 0c60-20 140-20 200 0v120c-60-18-140-18-200 0V0Z" />
		<path class="chalk-stroke" stroke-width="2.5" d="M0 0c-60-20-140-20-200 0v120c60-18 140-18 200 0V0Z" />
		<path class="chalk-stroke" stroke-width="1.5" d="M-80 40h50M-90 70h60M-75 100h40" opacity="0.5" />
		<path class="chalk-stroke" stroke-width="1.5" d="M30 40h50M40 70h60M35 100h40" opacity="0.5" />
	</g>

	<!-- flechas conectando notas -->
	<g class="chalk-stroke" stroke-width="2" opacity="0.3" fill="none">
		<path d="M280 240c80 40 120 20 200 10" />
		<path d="M600 200c60 80 80 160 100 240" />
		<path d="M950 280c-80 60-120 120-150 200" />
		<path d="M400 520c120-40 200-20 300 0" />
	</g>

	<!-- título dibujado -->
	<text x="600" y="90" text-anchor="middle" class="chalk-label" font-size="52" font-weight="700">escritos</text>
	<text x="600" y="125" text-anchor="middle" class="chalk-mono" font-size="13">notas en la pizarra</text>

	<!-- notas de posts (dinámicas) -->
	{
		posts.map((post, i) => {
			const pos = notePositions[i % notePositions.length];
			const title =
				post.title.length > 28 ? `${post.title.slice(0, 26)}…` : post.title;
			return (
				<a href={`/blog/${post.id}`}>
					<g transform={`translate(${pos.x} ${pos.y}) rotate(${pos.rot})`}>
						<rect class="hit-area" x="-10" y="-15" width="260" height="110" />
						<ellipse class="flat-blob" cx="120" cy="40" rx="130" ry="55" fill={pos.color} />
						<path
							class="draw chalk-stroke"
							stroke-width="2.5"
							d="M5 8c40-6 180-10 220 6 8 4 12 14 10 28l-4 48c-2 12-12 16-24 14l-200-4c-12-2-18-10-16-22l6-50c2-10 8-16 18-14Z"
						/>
						<path
							class="draw chalk-stroke"
							stroke-width="1.5"
							opacity="0.4"
							d="M20 30h180M25 50h160M22 68h140"
						/>
						<text class="chalk-label" x="20" y="38" font-size="26" font-weight="700">
							{title}
						</text>
						<text class="chalk-mono" x="20" y="58" font-size="11">
							{post.category}
						</text>
					</g>
				</a>
			);
		})
	}

	<!-- volver al mapa -->
	<a href="/">
		<g transform="translate(60 60)">
			<rect class="hit-area" x="-10" y="-25" width="120" height="50" />
			<path class="draw chalk-stroke" stroke-width="2.5" d="M50 0H10M10 0l14-12M10 0l14 12" />
			<text class="chalk-label" x="58" y="6" font-size="22">mapa</text>
		</g>
	</a>

	<!-- doodles sueltos -->
	<g class="chalk-stroke" stroke-width="2.5" opacity="0.35" fill="none">
		<path d="M1050 120l12 28h30l-24 18 9 28-27-19-27 19 9-28-24-18h30l12-28Z" />
		<circle cx="200" cy="700" r="20" />
		<path d="M192 695h2M208 695h2M195 708c4 6 10 6 16 0" />
	</g>

	<!-- tizas -->
	<rect x="80" y="760" width="100" height="10" rx="5" fill="#ebe6dc" opacity="0.7" />
	<rect x="200" y="763" width="50" height="6" rx="3" fill="#d5dfea" opacity="0.6" />
</svg>
