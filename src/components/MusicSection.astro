---
import Icon from './Icon.astro';
import { music } from '../data/site';
---

<section class="section" id="musica" aria-labelledby="musica-title">
	<div class="section__head">
		<div class="section__icon"><Icon name="music" size={18} /></div>
		<h2 class="section__title" id="musica-title">Música</h2>
	</div>
	<p class="section__lead">Álbumes para trabajar.</p>
	<div class="music-row">
		{
			music.map((item) => (
				<article class="music-card">
					<div class="music-card__art" aria-hidden="true">
						<Icon name="music" size={28} />
					</div>
					<h3 class="music-card__title">{item.title}</h3>
					<p class="music-card__artist">{item.artist}</p>
				</article>
			))
		}
	</div>
</section>
