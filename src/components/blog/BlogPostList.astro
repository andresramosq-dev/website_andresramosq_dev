---
import type { CollectionEntry } from 'astro:content';

interface Props {
	posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;

const fmt = (d: Date) =>
	d.toLocaleDateString('en-US', { day: 'numeric', month: 'short', year: 'numeric' });
---

<div class="posts-index" data-posts-list>
	{posts.map((post) => (
		<article class="posts-index__item">
			<a class="posts-index__link tag-box tag-box--c tag-box--solo" href={`/posts/${post.id}`}>
				<div class="tag-box__text posts-index__body">
					<header class="posts-index__head">
						<span class="posts-index__title">{post.data.title}</span>
						<time class="posts-index__date" datetime={post.data.pubDate.toISOString()}>
							{fmt(post.data.pubDate)}
						</time>
					</header>
					<span class="posts-index__desc">{post.data.description}</span>
				</div>
			</a>
		</article>
	))}
</div>
