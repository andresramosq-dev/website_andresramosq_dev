---
import type { CollectionEntry } from 'astro:content';
import { categoryLabel } from '../../data/site';
import type { CategoryId } from '../../data/site';

interface Props {
	posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;

const fmt = (d: Date) =>
	d.toLocaleDateString('en-US', { day: 'numeric', month: 'short', year: 'numeric' });
---

<ul class="blog-index" data-blog-list>
	{posts.map((post) => (
		<li
			class="blog-index__item"
			data-category={post.data.category}
			data-tags={post.data.tags.join(',')}
		>
			<a class="blog-index__link" href={`/blog/${post.id}`}>
				<span class="blog-index__title">{post.data.title}</span>
				<span class="blog-index__desc">{post.data.description}</span>
				<span class="blog-index__meta">
					<time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
					<span class="blog-index__dot" aria-hidden="true">·</span>
					<span>{categoryLabel[post.data.category]}</span>
					<span class="blog-index__dot" aria-hidden="true">·</span>
					<span>{post.data.minutes} min read</span>
				</span>
				{post.data.tags.length > 0 && (
					<span class="blog-index__tags">
						{post.data.tags.map((tag) => (
							<span class="blog-index__tag">#{tag}</span>
						))}
					</span>
				)}
			</a>
		</li>
	))}
</ul>
