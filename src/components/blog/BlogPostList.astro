---
import type { CollectionEntry } from 'astro:content';

interface Props {
	posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;

const fmt = (d: Date) =>
	d.toLocaleDateString('en-US', { day: 'numeric', month: 'short', year: 'numeric' });
---

<div class="posts-index" data-posts-list>
	{posts.map((post) => (
		<article class="posts-index__item">
			<a class="posts-index__link" href={`/posts/${post.id}`}>
				<header class="posts-index__head">
					<h2 class="posts-index__title">{post.data.title}</h2>
					<time class="posts-index__date" datetime={post.data.pubDate.toISOString()}>
						{fmt(post.data.pubDate)}
					</time>
				</header>
				<p class="posts-index__desc">{post.data.description}</p>
			</a>
		</article>
	))}
</div>
