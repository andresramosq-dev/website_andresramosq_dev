---
import type { CategoryId } from '../../data/site';

interface CategoryOption {
	id: CategoryId;
	label: string;
}

interface Props {
	activeCategory: CategoryId | 'all';
	activeTag: string | 'all';
	categories: CategoryOption[];
	tags: string[];
	categoryLabels: Record<string, string>;
}

const { activeCategory, activeTag, categories, tags, categoryLabels } = Astro.props;

function hrefCategory(category: CategoryId | 'all') {
	if (category === 'all') return '/posts';
	return `/posts?category=${category}`;
}

function hrefTag(tag: string | 'all') {
	if (tag === 'all') return '/posts';
	return `/posts?tag=${encodeURIComponent(tag)}`;
}

const activeCategoryLabel =
	activeCategory === 'all' ? null : (categories.find((c) => c.id === activeCategory)?.label ?? activeCategory);

let summary = 'all';
if (activeTag !== 'all') summary = `#${activeTag}`;
else if (activeCategoryLabel) summary = activeCategoryLabel;

const labelsJson = JSON.stringify(categoryLabels);
---

<div
	class="posts-filters"
	data-posts-filters
	data-open="0"
	data-active-category={activeCategory}
	data-active-tag={activeTag}
	data-category-labels={labelsJson}
>
	<div class="posts-filters__bar">
		<p class="posts-filters__status">
			<span class="posts-filters__key">filters</span>
			<span class="posts-filters__val" data-posts-filter-summary>{summary}</span>
		</p>
		<button
			type="button"
			class="posts-filters__toggle"
			data-posts-filters-toggle
			aria-expanded="false"
			aria-controls="posts-filters-panel"
		>
			Show filters
		</button>
	</div>

	<div
		id="posts-filters-panel"
		class="posts-filters__panel"
		data-posts-filters-panel
		hidden
	>
		<nav class="blog-tags" aria-label="Filter posts">
			<div class="blog-tags__group">
				<p class="blog-tags__label">category</p>
				<ul class="blog-tags__list">
					<li>
						<a
							href={hrefCategory('all')}
							class:list={[
								'blog-tags__chip',
								activeCategory === 'all' && activeTag === 'all' && 'blog-tags__chip--on',
							]}
							data-filter-kind="category"
							data-filter-value="all"
							data-astro-reload
						>
							all
						</a>
					</li>
					{categories.map((cat) => (
						<li>
							<a
								href={hrefCategory(cat.id)}
								class:list={[
									'blog-tags__chip',
									activeCategory === cat.id && activeTag === 'all' && 'blog-tags__chip--on',
								]}
								data-filter-kind="category"
								data-filter-value={cat.id}
								data-astro-reload
							>
								{cat.label}
							</a>
						</li>
					))}
				</ul>
			</div>
			{tags.length > 0 && (
				<div class="blog-tags__group">
					<p class="blog-tags__label">tags</p>
					<ul class="blog-tags__list">
						<li>
							<a
								href={hrefTag('all')}
								class:list={[
									'blog-tags__chip',
									activeTag === 'all' && activeCategory === 'all' && 'blog-tags__chip--on',
								]}
								data-filter-kind="tag"
								data-filter-value="all"
								data-astro-reload
							>
								all
							</a>
						</li>
						{tags.map((tag) => (
							<li>
								<a
									href={hrefTag(tag)}
									class:list={[
										'blog-tags__chip',
										'blog-tags__chip--tag',
										activeTag === tag && 'blog-tags__chip--on',
									]}
									data-filter-kind="tag"
									data-filter-value={tag}
									data-astro-reload
								>
									#{tag}
								</a>
							</li>
						))}
					</ul>
				</div>
			)}
		</nav>
	</div>
</div>

<script>
	function parseCategoryLabels(root: HTMLElement): Record<string, string> {
		try {
			return JSON.parse(root.dataset.categoryLabels ?? '{}') as Record<string, string>;
		} catch {
			return {};
		}
	}

	function syncFilterUi(root: HTMLElement) {
		const params = new URLSearchParams(window.location.search);
		const tag = params.get('tag');
		const category = params.get('category');
		const labels = parseCategoryLabels(root);

		let summary = 'all';
		if (tag) summary = `#${tag}`;
		else if (category) summary = labels[category] ?? category;

		const summaryEl = root.querySelector('[data-posts-filter-summary]');
		if (summaryEl) summaryEl.textContent = summary;

		root.querySelectorAll<HTMLAnchorElement>('.blog-tags__chip').forEach((chip) => {
			const kind = chip.dataset.filterKind;
			const value = chip.dataset.filterValue ?? '';
			let on = false;
			if (kind === 'tag') {
				on = value === 'all' ? !tag && !category : tag === value;
			} else if (kind === 'category') {
				on = value === 'all' ? !tag && !category : !tag && category === value;
			}
			chip.classList.toggle('blog-tags__chip--on', on);
		});
	}

	function bindPostsFilters(root: HTMLElement) {
		const panel = root.querySelector<HTMLElement>('[data-posts-filters-panel]');
		const toggle = root.querySelector<HTMLButtonElement>('[data-posts-filters-toggle]');
		if (!panel || !toggle) return;

		const setOpen = (open: boolean) => {
			panel.hidden = !open;
			toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
			toggle.textContent = open ? 'Hide filters' : 'Show filters';
			root.dataset.open = open ? '1' : '0';
		};

		if (root.dataset.bound !== '1') {
			root.dataset.bound = '1';
			toggle.addEventListener('click', () => {
				setOpen(panel.hidden);
			});
			root.querySelectorAll<HTMLAnchorElement>('.blog-tags__chip').forEach((link) => {
				link.addEventListener('click', () => {
					setOpen(false);
				});
			});
		}

		syncFilterUi(root);
		setOpen(false);
	}

	document.querySelectorAll<HTMLElement>('[data-posts-filters]').forEach(bindPostsFilters);
	document.addEventListener('astro:page-load', () => {
		document.querySelectorAll<HTMLElement>('[data-posts-filters]').forEach(bindPostsFilters);
	});
</script>
