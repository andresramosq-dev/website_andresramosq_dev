---
interface Props {
	name: 'spark' | 'code' | 'compass' | 'pen' | 'arrow' | 'book' | 'user' | 'folder' | 'mail' | 'tag' | 'clock' | 'home';
	size?: number;
	class?: string;
}

const { name, size = 22, class: className } = Astro.props;
---

<svg
	class:list={['icon', className]}
	width={size}
	height={size}
	viewBox="0 0 24 24"
	fill="none"
	xmlns="http://www.w3.org/2000/svg"
	aria-hidden="true"
>
	{
		name === 'spark' && (
			<path
				d="m12 3 1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8L12 3Zm6 10 1 2.8L22 17l-3 1.2L18 21l-1-2.8L14 17l3-1.2L18 13Z"
				stroke="currentColor"
				stroke-width="1.7"
				stroke-linejoin="round"
			/>
		)
	}
	{
		name === 'code' && (
			<path
				d="M8 8 4 12l4 4M16 8l4 4-4 4M13 5l-2 14"
				stroke="currentColor"
				stroke-width="1.7"
				stroke-linecap="round"
				stroke-linejoin="round"
			/>
		)
	}
	{
		name === 'compass' && (
			<>
				<circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.7" />
				<path
					d="m15.5 8.5-2.2 5.8-5.8 2.2 2.2-5.8 5.8-2.2Z"
					stroke="currentColor"
					stroke-width="1.7"
					stroke-linejoin="round"
				/>
			</>
		)
	}
	{
		name === 'pen' && (
			<path
				d="m12 20 8-8-4-4-8 8-1 4 5-1Zm4-12 4 4"
				stroke="currentColor"
				stroke-width="1.7"
				stroke-linecap="round"
				stroke-linejoin="round"
			/>
		)
	}
	{
		name === 'arrow' && (
			<path
				d="M5 12h12m-5-5 5 5-5 5"
				stroke="currentColor"
				stroke-width="1.7"
				stroke-linecap="round"
				stroke-linejoin="round"
			/>
		)
	}
	{
		name === 'book' && (
			<path
				d="M4 5h10a3 3 0 0 1 3 3v12H7a3 3 0 0 0-3 3V5Zm0 0v15"
				stroke="currentColor"
				stroke-width="1.7"
				stroke-linecap="round"
				stroke-linejoin="round"
			/>
		)
	}
	{
		name === 'user' && (
			<>
				<circle cx="12" cy="8" r="3.2" stroke="currentColor" stroke-width="1.7" />
				<path
					d="M5 19c1.4-2.8 3.8-4.2 7-4.2s5.6 1.4 7 4.2"
					stroke="currentColor"
					stroke-width="1.7"
					stroke-linecap="round"
				/>
			</>
		)
	}
	{
		name === 'folder' && (
			<path
				d="M3 7a2 2 0 0 1 2-2h5l2 2h7a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7Z"
				stroke="currentColor"
				stroke-width="1.7"
				stroke-linejoin="round"
			/>
		)
	}
	{
		name === 'mail' && (
			<>
				<rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.7" />
				<path
					d="m4 7 8 6 8-6"
					stroke="currentColor"
					stroke-width="1.7"
					stroke-linecap="round"
					stroke-linejoin="round"
				/>
			</>
		)
	}
	{
		name === 'tag' && (
			<path
				d="M3 12V4h8l10 10-8 8L3 12Z"
				stroke="currentColor"
				stroke-width="1.7"
				stroke-linejoin="round"
			/>
		)
	}
	{
		name === 'clock' && (
			<>
				<circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.7" />
				<path
					d="M12 7v5l3 2"
					stroke="currentColor"
					stroke-width="1.7"
					stroke-linecap="round"
					stroke-linejoin="round"
				/>
			</>
		)
	}
	{
		name === 'home' && (
			<path
				d="m4 11 8-7 8 7v9a1 1 0 0 1-1 1h-5v-6H10v6H5a1 1 0 0 1-1-1v-9Z"
				stroke="currentColor"
				stroke-width="1.7"
				stroke-linejoin="round"
			/>
		)
	}
</svg>
