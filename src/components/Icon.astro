---
interface Props {
	name: 'pen' | 'book' | 'folder' | 'user' | 'arrow' | 'github' | 'mail' | 'music';
	size?: number;
	class?: string;
}

const { name, size = 20, class: className } = Astro.props;
---

<svg
	class:list={['icon', className]}
	width={size}
	height={size}
	viewBox="0 0 24 24"
	fill="none"
	xmlns="http://www.w3.org/2000/svg"
	aria-hidden="true"
>
	{
		name === 'pen' && (
			<path
				d="m12 20 8-8-4-4-8 8-1 4 5-1Zm4-12 4 4"
				stroke="currentColor"
				stroke-width="1.7"
				stroke-linecap="round"
				stroke-linejoin="round"
			/>
		)
	}
	{
		name === 'book' && (
			<path
				d="M4 5h10a3 3 0 0 1 3 3v12H7a3 3 0 0 0-3 3V5Zm0 0v15"
				stroke="currentColor"
				stroke-width="1.7"
				stroke-linecap="round"
				stroke-linejoin="round"
			/>
		)
	}
	{
		name === 'folder' && (
			<path
				d="M3 7a2 2 0 0 1 2-2h5l2 2h7a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7Z"
				stroke="currentColor"
				stroke-width="1.7"
				stroke-linejoin="round"
			/>
		)
	}
	{
		name === 'user' && (
			<>
				<circle cx="12" cy="8" r="3.2" stroke="currentColor" stroke-width="1.7" />
				<path
					d="M5 19c1.4-2.8 3.8-4.2 7-4.2s5.6 1.4 7 4.2"
					stroke="currentColor"
					stroke-width="1.7"
					stroke-linecap="round"
				/>
			</>
		)
	}
	{
		name === 'arrow' && (
			<path
				d="M5 12h12m-5-5 5 5-5 5"
				stroke="currentColor"
				stroke-width="1.7"
				stroke-linecap="round"
				stroke-linejoin="round"
			/>
		)
	}
	{
		name === 'mail' && (
			<>
				<rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.7" />
				<path
					d="m4 7 8 6 8-6"
					stroke="currentColor"
					stroke-width="1.7"
					stroke-linecap="round"
					stroke-linejoin="round"
				/>
			</>
		)
	}
	{
		name === 'github' && (
			<path
				fill="currentColor"
				d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.1-1.47-1.1-1.47-.9-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.89 1.52 2.34 1.08 2.91.83.09-.65.35-1.08.63-1.33-2.22-.25-4.56-1.11-4.56-4.95 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02A9.56 9.56 0 0 1 12 6.8c.85 0 1.71.11 2.51.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.85-2.34 4.7-4.57 4.95.36.31.68.92.68 1.85v2.74c0 .27.18.58.69.48A10 10 0 0 0 12 2Z"
			/>
		)
	}
	{
		name === 'music' && (
			<>
				<path
					d="M9 18V6l11-2v12"
					stroke="currentColor"
					stroke-width="1.7"
					stroke-linecap="round"
					stroke-linejoin="round"
				/>
				<circle cx="7" cy="18" r="2.4" stroke="currentColor" stroke-width="1.7" />
				<circle cx="18" cy="16" r="2.4" stroke="currentColor" stroke-width="1.7" />
			</>
		)
	}
</svg>
