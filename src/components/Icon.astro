---
interface Props {
	name: 'github' | 'linkedin' | 'mail' | 'spotify' | 'phone' | 'cv';
	size?: number;
	class?: string;
}

const { name, size = 22, class: className } = Astro.props;
---

<svg
	class:list={['icon', className]}
	width={size}
	height={size}
	viewBox="0 0 24 24"
	fill="none"
	xmlns="http://www.w3.org/2000/svg"
	aria-hidden="true"
>
	{
		name === 'github' && (
			<path
				d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 18 4.77 5.07 5.07 0 0 0 17.91 1S16.73.65 13 2.48a13.38 13.38 0 0 0-7 0C2.27.65 1.09 1 1.09 1A5.07 5.07 0 0 0 1 4.77 5.44 5.44 0 0 0 3.5 8.55c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
				stroke="currentColor"
				stroke-width="1.7"
				stroke-linecap="round"
				stroke-linejoin="round"
			/>
		)
	}
	{
		name === 'linkedin' && (
			<>
				<rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.7" />
				<path
					d="M8 11v5M8 8v.01M12 16v-5c0-1.1.9-2 2-2s2 .9 2 2v5"
					stroke="currentColor"
					stroke-width="1.7"
					stroke-linecap="round"
					stroke-linejoin="round"
				/>
			</>
		)
	}
	{
		name === 'mail' && (
			<>
				<rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.7" />
				<path
					d="m4 7 8 6 8-6"
					stroke="currentColor"
					stroke-width="1.7"
					stroke-linecap="round"
					stroke-linejoin="round"
				/>
			</>
		)
	}
	{
		name === 'spotify' && (
			<>
				<circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.7" />
				<path
					d="M8 10.5c3.5-1 7.5-.5 9.5 1M7.5 13.5c3-.8 6.5-.3 9 1.2M7 16.5c2.5-.6 5.5-.2 7.5 1"
					stroke="currentColor"
					stroke-width="1.7"
					stroke-linecap="round"
				/>
			</>
		)
	}
	{
		name === 'phone' && (
			<path
				d="M6.5 4h3l1.5 4-2 1.5a11 11 0 0 0 5 5L17.5 12.5 21.5 14v3a2 2 0 0 1-2.2 2A17 17 0 0 1 4 6.2 2 2 0 0 1 6.5 4Z"
				stroke="currentColor"
				stroke-width="1.7"
				stroke-linecap="round"
				stroke-linejoin="round"
			/>
		)
	}
	{
		name === 'cv' && (
			<>
				<path
					d="M7 3h7l4 4v14a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1Z"
					stroke="currentColor"
					stroke-width="1.7"
					stroke-linejoin="round"
				/>
				<path
					d="M14 3v4h4M9 12h6M9 16h6M9 8h2"
					stroke="currentColor"
					stroke-width="1.7"
					stroke-linecap="round"
					stroke-linejoin="round"
				/>
			</>
		)
	}
</svg>
