---
import { site } from '../data/site';

interface Props {
	segment: string;
	title: string;
}

const { segment, title } = Astro.props;
---

<header class="page-hd">
	<h1 class="page-hd__title">{title}</h1>
	<p class="page-hd__path">
		<span class="prompt">{site.user}</span>@<span class="host">{site.domain}</span>:~/{segment}
	</p>
</header>
