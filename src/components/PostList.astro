---
import { getCollection } from 'astro:content';
import Icon from './Icon.astro';

interface Props {
	limit?: number;
	featured?: boolean;
}

const { limit, featured = true } = Astro.props;

const posts = (await getCollection('blog', ({ data }) => !data.draft))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, limit ?? Infinity);

const [first, ...rest] = featured && posts.length > 0 ? posts : [undefined, ...posts];
const list = featured ? rest : posts;
---

{
	first && (
		<a class="featured" href={`/blog/${first.id}`}>
			<div>
				<div class="featured__meta">
					<span>Destacado</span>
					<span>
						{first.data.pubDate.toLocaleDateString('es-ES', {
							year: 'numeric',
							month: 'short',
							day: 'numeric',
						})}
					</span>
					<span>{first.data.section}</span>
				</div>
				<h3 class="featured__title">{first.data.title}</h3>
				<p class="featured__desc">{first.data.description}</p>
				<span class="featured__cta">
					Leer artículo
					<Icon name="arrow" size={16} />
				</span>
			</div>
			<div class="featured__visual" aria-hidden="true">
				<Icon name="book" size={42} />
			</div>
		</a>
	)
}

{
	list.length > 0 && (
		<div class="post-list">
			{list.map((post) => (
				<a class="post-item" href={`/blog/${post.id}`}>
					<div class="post-item__meta">
						<span>
							{post.data.pubDate.toLocaleDateString('es-ES', {
								year: 'numeric',
								month: 'short',
								day: 'numeric',
							})}
						</span>
						<span>{post.data.section}</span>
					</div>
					<h3 class="post-item__title">{post.data.title}</h3>
					<p class="post-item__desc">{post.data.description}</p>
				</a>
			))}
		</div>
	)
}
