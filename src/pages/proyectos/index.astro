---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPath from '../../components/TermPath.astro';
import TermPanel from '../../components/TermPanel.astro';
import FeedList from '../../components/FeedList.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => b.data.year - a.data.year);
---

<BaseLayout title="proyectos" path="/proyectos">
  <TermPath path="/proyectos" />

  <TermPanel label="proyectos/">
    <FeedList
      items={projects.map((p) => ({
        href: `/proyectos/${p.id}`,
        title: p.data.title,
        meta: String(p.data.year),
      }))}
      dir
    />
  </TermPanel>
</BaseLayout>
