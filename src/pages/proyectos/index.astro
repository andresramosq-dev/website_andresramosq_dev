---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';

const projects = (await getCollection('projects')).sort((a, b) => b.data.year - a.data.year);
---

<BaseLayout title="Proyectos" description="Trabajo seleccionado." currentPath="/proyectos">
	<header class="page-head">
		<p class="hero__kicker"><Icon name="folder" size={16} /> Portfolio</p>
		<h1>Proyectos</h1>
		<p>Una selección corta de trabajo. El centro del sitio es el blog.</p>
	</header>
	<div class="project-list">
		{
			projects.map((project) => (
				<article class="project-card" id={project.id}>
					<p class="post-card__meta">
						{project.data.year} · {project.data.status}
					</p>
					<h2>{project.data.title}</h2>
					<p>{project.data.description}</p>
					<div class="project-card__stack">
						{project.data.stack.map((tech) => (
							<span>{tech}</span>
						))}
					</div>
				</article>
			))
		}
	</div>
</BaseLayout>
