---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArtIllus from '../../components/ArtIllus.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => b.data.year - a.data.year);
---

<BaseLayout title="Proyectos">
  <div class="wrap">
    <header class="pg-head">
      <h1>Proyectos</h1>
      <p>Trabajo personal y experimentos.</p>
    </header>
    {projects.map((p) => (
      <a class="proj" href={p.data.url ?? '#'}>
        <ArtIllus variant="codigo" />
        <div>
          <p class="proj__meta">{p.data.year} · {p.data.stack.join(', ')}</p>
          <h2 class="proj__title">{p.data.title}</h2>
          <p class="proj__desc">{p.data.description}</p>
        </div>
      </a>
    ))}
  </div>
</BaseLayout>
