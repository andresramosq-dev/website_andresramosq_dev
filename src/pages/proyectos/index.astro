---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermLine from '../../components/TermLine.astro';
import PromptCursor from '../../components/PromptCursor.astro';
import FeedList from '../../components/FeedList.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => b.data.year - a.data.year);
---

<BaseLayout title="proyectos" path="/proyectos">
  <TermLine cmd="ls proyectos/">
    <FeedList
      items={projects.map((p) => ({
        href: `/proyectos/${p.id}`,
        title: p.data.title,
        meta: String(p.data.year),
      }))}
    />
  </TermLine>
  <PromptCursor />
</BaseLayout>
