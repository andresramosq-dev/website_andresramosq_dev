---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';

const projects = (await getCollection('projects')).sort((a, b) => b.data.year - a.data.year);
---

<BaseLayout title="Proyectos" description="Selección de trabajo." currentPath="/proyectos">
	<section class="page-hero">
		<a class="back-link" href="/"><Icon name="arrow" size={16} /> Inicio</a>
		<h1>Proyectos</h1>
		<p>Fichas cortas con stack y estado.</p>
	</section>
	<div class="card-grid list-stack">
		{
			projects.map((project) => (
				<article class="card" id={project.id}>
					<div class="card__mark">
						<Icon name="box" size={18} />
					</div>
					<p class="card__meta">
						{project.data.year} · {project.data.status}
					</p>
					<h2 class="card__title">{project.data.title}</h2>
					<p class="card__text">{project.data.description}</p>
					<div class="card__foot">
						{project.data.stack.map((tech) => (
							<span class="chip">{tech}</span>
						))}
					</div>
				</article>
			))
		}
	</div>
</BaseLayout>
