---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = (await getCollection('projects')).sort((a, b) => b.data.year - a.data.year);
---

<BaseLayout title="Proyectos" description="Trabajo seleccionado." currentPath="/proyectos">
	<header class="page-head">
		<h1>Proyectos</h1>
		<p>Selección breve. El centro sigue siendo escribir.</p>
	</header>

	<div class="project-list">
		{
			projects.map((project) => (
				<article class="project-item" id={project.id}>
					<p class="project-item__meta">
						{project.data.year} · {project.data.status}
					</p>
					<h2>{project.data.title}</h2>
					<p>{project.data.description}</p>
					<p class="project-item__stack">{project.data.stack.join(' · ')}</p>
				</article>
			))
		}
	</div>
</BaseLayout>
