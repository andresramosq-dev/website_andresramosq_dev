---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import TermBlock from '../../components/TermBlock.astro';
import FeedList from '../../components/FeedList.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => b.data.year - a.data.year);
---

<BaseLayout title="proyectos" path="/proyectos">
  <PageHeader segment="proyectos" title="Proyectos" />

  <TermBlock cmd="ls proyectos/">
    <FeedList
      items={projects.map((p) => ({
        href: `/proyectos/${p.id}`,
        title: p.data.title,
        meta: String(p.data.year),
      }))}
    />
  </TermBlock>
</BaseLayout>
