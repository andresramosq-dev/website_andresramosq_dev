---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermLine from '../../components/TermLine.astro';
import PromptCursor from '../../components/PromptCursor.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({ params: { slug: project.id }, props: { project } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={project.data.title} description={project.data.description} path="/proyectos">
  <TermLine cmd={`cat "${project.data.title}"`}>
    <p class="out out--lg">{project.data.title}</p>
    <p class="article__meta">{project.data.year} · {project.data.status}</p>
    {project.data.url && (
      <p class="out">
        <a href={project.data.url} target="_blank" rel="noreferrer">ver repositorio →</a>
      </p>
    )}
    <div class="article__body">
      <Content />
    </div>
    <a class="mt" href="/proyectos">← ./proyectos</a>
  </TermLine>
  <PromptCursor />
</BaseLayout>
