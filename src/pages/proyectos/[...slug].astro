---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import TermBlock from '../../components/TermBlock.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({ params: { slug: project.id }, props: { project } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={project.data.title} description={project.data.description} path="/proyectos">
  <PageHeader segment={`proyectos/${project.id}`} title={project.data.title} />

  <TermBlock cmd={`less "${project.data.title}"`}>
    <p class="article__meta">{project.data.year} · {project.data.status}</p>
    {project.data.url && (
      <p style="margin:-0.5rem 0 1rem">
        <a href={project.data.url} target="_blank" rel="noreferrer">ver repositorio →</a>
      </p>
    )}
    <div class="article__body">
      <Content />
    </div>
    <a class="mt-link" href="/proyectos">← proyectos</a>
  </TermBlock>
</BaseLayout>
