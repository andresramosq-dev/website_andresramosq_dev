---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPath from '../../components/TermPath.astro';
import TermPanel from '../../components/TermPanel.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({ params: { slug: project.id }, props: { project } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const fullPath = `/proyectos/${project.id}`;
---

<BaseLayout title={project.data.title} description={project.data.description} path={fullPath}>
  <TermPath path={fullPath} />

  <TermPanel label={project.data.title}>
    <p class="article__meta">{project.data.year} · {project.data.status}</p>
    {project.data.url && (
      <p class="article__link">
        <a href={project.data.url} target="_blank" rel="noreferrer">repositorio →</a>
      </p>
    )}
    <div class="article__body">
      <Content />
    </div>
    <a class="mt-link" href="/proyectos">~/proyectos</a>
  </TermPanel>
</BaseLayout>
