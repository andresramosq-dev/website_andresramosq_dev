---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { categories } from '../../data/site';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const counts = Object.fromEntries(
  categories.map((c) => [c.id, posts.filter((p) => p.data.category === c.id).length])
);
---

<BaseLayout title="tags" path="/categorias">
  <header class="pg-head">
    <p class="crumb"><a href="/">~</a> / tags</p>
    <h1 class="pg-title">Tags</h1>
    <p class="pg-desc">Artículos por categoría.</p>
  </header>

  <ul class="list">
    {
      categories.map((cat) => (
        <li>
          <a href={`/categorias/${cat.id}`}>
            <p class="list__title">#{cat.label}</p>
            <p class="list__meta">{counts[cat.id]} posts · {cat.description}</p>
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>
