---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import ArtIcon from '../../components/ArtIcon.astro';
import { getCollection } from 'astro:content';
import { categories } from '../../data/site';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const grouped = categories.map((cat) => ({
  ...cat,
  posts: posts
    .filter((p) => p.data.category === cat.id)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
}));
---

<BaseLayout title="Categorías" description="Categorías del blog">
  <div class="wrap">
    <header class="page-head">
      <h1>Categorías</h1>
      <p>Artículos organizados por tema.</p>
    </header>

    {
      grouped.map((group) => (
        <section class="cluster">
          <h2 style={`--cluster-color: ${group.color}`}>
            <ArtIcon name={group.icon} color={group.color} size="sm" />
            {group.label}
          </h2>
          {group.posts.length === 0 ? (
            <p class="empty">No hay artículos en esta categoría.</p>
          ) : (
            <div class="card-grid">
              {group.posts.map((post) => (
                <BlogCard
                  href={`/blog/${post.id}`}
                  title={post.data.title}
                  description={post.data.description}
                  date={post.data.pubDate}
                  minutes={post.data.minutes}
                  category={post.data.category}
                  icon={group.icon}
                />
              ))}
            </div>
          )}
        </section>
      ))
    }
  </div>
</BaseLayout>
