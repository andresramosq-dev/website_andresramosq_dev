---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import TermBlock from '../../components/TermBlock.astro';
import FeedList from '../../components/FeedList.astro';
import { getCollection } from 'astro:content';
import { categories } from '../../data/site';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const counts = Object.fromEntries(
  categories.map((c) => [c.id, posts.filter((p) => p.data.category === c.id).length])
);
---

<BaseLayout title="tags" path="/categorias">
  <PageHeader segment="tags" title="Tags" />

  <TermBlock cmd="ls tags/">
    <FeedList
      items={categories.map((c) => ({
        href: `/categorias/${c.id}`,
        title: c.label,
        meta: `${counts[c.id]} posts`,
      }))}
    />
  </TermBlock>
</BaseLayout>
