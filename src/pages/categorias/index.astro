---
import BaseLayout from '../../layouts/BaseLayout.astro';
import IdeaNode from '../../components/IdeaNode.astro';
import BoardLines from '../../components/BoardLines.astro';
import { getCollection } from 'astro:content';
import { categories } from '../../data/site';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const grouped = categories.map((cat) => ({
  ...cat,
  posts: posts
    .filter((p) => p.data.category === cat.id)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
}));

const clusterLines = [
  { d: 'M20 20 C35 30, 50 25, 65 35' },
  { d: 'M65 35 C75 45, 80 55, 75 70' },
  { d: 'M20 20 C30 50, 40 65, 55 75' },
];
---

<BaseLayout title="Temas" description="Categorías del blog">
  <section class="idea-wall" style="min-height: 280px; margin-bottom: 1rem;">
    <img class="board-canvas" src="/images/board-canvas.svg" alt="" width="1400" height="900" />
    <BoardLines lines={[{ d: 'M50 50 C30 30, 70 30, 50 50' }]} />
    <IdeaNode
      class="wall--title"
      title="temas"
      subtitle="rutas de lectura"
      icon="tag"
      color="#e8e4dc"
      size="lg"
      frame={2}
    />
  </section>

  {
    grouped.map((group) => (
      <section class="cluster-wall" aria-label={group.label}>
        <img class="board-canvas" src="/images/board-canvas.svg" alt="" width="1400" height="400" />
        <BoardLines lines={clusterLines} />

        <IdeaNode
          class="cluster--label"
          href={`/categorias/${group.id}`}
          title={group.label}
          subtitle={group.description}
          icon={group.icon}
          color={group.color}
          frame={1}
        />

        {group.posts.map((post, i) => (
          <IdeaNode
            class={`cluster--p${(i % 3) + 1}`}
            href={`/blog/${post.id}`}
            title={post.data.title}
            subtitle={post.data.pubDate.toLocaleDateString('es-ES', {
              day: 'numeric',
              month: 'short',
            })}
            icon={group.icon}
            color={group.color}
            size="sm"
            frame={((i % 5) + 1) as 1 | 2 | 3 | 4 | 5}
          />
        ))}
      </section>
    ))
  }
</BaseLayout>
