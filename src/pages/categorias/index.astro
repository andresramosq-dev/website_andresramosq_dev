---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermLine from '../../components/TermLine.astro';
import PromptCursor from '../../components/PromptCursor.astro';
import FeedList from '../../components/FeedList.astro';
import { getCollection } from 'astro:content';
import { categories } from '../../data/site';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const counts = Object.fromEntries(
  categories.map((c) => [c.id, posts.filter((p) => p.data.category === c.id).length])
);
---

<BaseLayout title="tags" path="/categorias">
  <TermLine cmd="ls tags/">
    <FeedList
      items={categories.map((c) => ({
        href: `/categorias/${c.id}`,
        title: c.label,
        meta: `${counts[c.id]} posts`,
      }))}
    />
  </TermLine>
  <PromptCursor />
</BaseLayout>
