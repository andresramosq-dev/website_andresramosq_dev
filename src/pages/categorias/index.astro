---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { categories } from '../../data/site';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const counts = Object.fromEntries(
  categories.map((c) => [c.id, posts.filter((p) => p.data.category === c.id).length])
);
---

<BaseLayout title="tags" path="/categorias">
  <p class="crumb"><a href="/">~</a> / tags</p>
  <h1 class="pg-title">Tags</h1>
  <p class="pg-desc">Artículos por categoría.</p>

  <ul class="posts">
    {
      categories.map((cat) => (
        <li>
          <a href={`/categorias/${cat.id}`}>
            <span class="posts__date">{counts[cat.id]} posts</span>
            <span class="posts__title">#{cat.label}</span>
            <span class="posts__tag">{cat.description}</span>
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>
