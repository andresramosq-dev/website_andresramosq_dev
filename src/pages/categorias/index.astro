---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostTile from '../../components/PostTile.astro';
import ArtIllus from '../../components/ArtIllus.astro';
import { getCollection } from 'astro:content';
import { categories } from '../../data/site';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const grouped = categories.map((cat) => ({
  ...cat,
  posts: posts.filter((p) => p.data.category === cat.id)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
}));
---

<BaseLayout title="Categorías">
  <div class="wrap">
    <header class="pg-head">
      <h1>Categorías</h1>
      <p>Artículos por tema.</p>
    </header>
    {grouped.map((g) => (
      <section class="cluster">
        <h2>{g.label}</h2>
        {g.posts.length === 0 ? (
          <p style="color:var(--muted)">Sin artículos.</p>
        ) : (
          <div class="post-grid">
            {g.posts.map((post, i) => (
              <PostTile
                href={`/blog/${post.id}`}
                title={post.data.title}
                description={post.data.description}
                date={post.data.pubDate}
                minutes={post.data.minutes}
                category={post.data.category}
                featured={i === 0 && g.posts.length > 1}
              />
            ))}
          </div>
        )}
      </section>
    ))}
  </div>
</BaseLayout>
