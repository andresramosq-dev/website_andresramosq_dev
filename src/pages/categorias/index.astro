---
import BaseLayout from '../../layouts/BaseLayout.astro';
import IdeaNode from '../../components/IdeaNode.astro';
import { getCollection } from 'astro:content';
import { categories } from '../../data/site';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const grouped = categories.map((cat) => ({
  ...cat,
  posts: posts
    .filter((p) => p.data.category === cat.id)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
}));
---

<BaseLayout title="Temas" description="Categorías del blog">
  <section class="board-section">
    <h1 class="board-section__title">Temas</h1>

    {
      grouped.map((group, gi) => (
        <div class="board-cluster">
          <h2 class="board-cluster__label">
            <span>{group.label}</span>
          </h2>
          <div class="board-cluster__nodes">
            {group.posts.length === 0 ? (
              <p style="color: var(--chalk-dim); font-size: 1.2rem;">sin notas aún</p>
            ) : (
              group.posts.map((post, pi) => (
                <IdeaNode
                  href={`/blog/${post.id}`}
                  title={post.data.title}
                  subtitle={group.description}
                  icon={group.icon}
                  size="sm"
                  frame={(((gi + pi) % 5) + 1) as 1 | 2 | 3 | 4 | 5}
                />
              ))
            )}
          </div>
        </div>
      ))
    }
  </section>
</BaseLayout>
