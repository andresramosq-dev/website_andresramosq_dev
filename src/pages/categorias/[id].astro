---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import IdeaNode from '../../components/IdeaNode.astro';
import { categories } from '../../data/site';

export function getStaticPaths() {
	return categories.map((category) => ({
		params: { id: category.id },
		props: { category },
	}));
}

const { category } = Astro.props;
const posts = (
	await getCollection('blog', ({ data }) => !data.draft && data.category === category.id)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={category.label} description={category.description}>
	<section class="board-section">
		<a class="board-back" href="/categorias">← temas</a>
		<h1 class="board-section__title">{category.label}</h1>
		<p style="color: var(--chalk-dim); font-size: 1.2rem; margin: -1rem 0 1.5rem;">{category.description}</p>

		<div class="board-cluster__nodes">
			{
				posts.map((post, i) => (
					<IdeaNode
						href={`/blog/${post.id}`}
						title={post.data.title}
						subtitle={post.data.pubDate.toLocaleDateString('es-ES', {
							day: 'numeric',
							month: 'short',
						})}
						icon={category.icon}
						size="sm"
						frame={((i % 5) + 1) as 1 | 2 | 3 | 4 | 5}
					/>
				))
			}
		</div>
	</section>
</BaseLayout>
