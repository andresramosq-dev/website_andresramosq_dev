---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermLine from '../../components/TermLine.astro';
import PromptCursor from '../../components/PromptCursor.astro';
import FeedList from '../../components/FeedList.astro';
import { categories } from '../../data/site';

export function getStaticPaths() {
  return categories.map((c) => ({ params: { id: c.id }, props: { category: c } }));
}

const { category } = Astro.props;
const posts = (await getCollection('blog', ({ data }) => !data.draft && data.category === category.id))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = (d: Date) => d.toLocaleDateString('es-ES', { month: 'short', year: 'numeric' });
---

<BaseLayout title={category.label} path="/categorias">
  <TermLine cmd={`ls blog/ --tag=${category.label}`}>
    <FeedList
      items={posts.map((p) => ({
        href: `/blog/${p.id}`,
        title: p.data.title,
        meta: fmt(p.data.pubDate),
      }))}
    />
  </TermLine>
  <PromptCursor />
</BaseLayout>
