---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import TermBlock from '../../components/TermBlock.astro';
import FeedList from '../../components/FeedList.astro';
import { categories } from '../../data/site';

export function getStaticPaths() {
  return categories.map((c) => ({ params: { id: c.id }, props: { category: c } }));
}

const { category } = Astro.props;
const posts = (await getCollection('blog', ({ data }) => !data.draft && data.category === category.id))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = (d: Date) => d.toLocaleDateString('es-ES', { month: 'short', year: 'numeric' });
---

<BaseLayout title={category.label} path="/categorias">
  <PageHeader segment={`tags/${category.label}`} title={category.label} />

  <TermBlock cmd={`ls blog/ --tag=${category.label}`}>
    <FeedList
      items={posts.map((p) => ({
        href: `/blog/${p.id}`,
        title: `${p.id}.md`,
        meta: fmt(p.data.pubDate),
      }))}
    />
  </TermBlock>
</BaseLayout>
