---
import { getCollection } from 'astro:content';
import MuralLayout from '../../layouts/MuralLayout.astro';
import BlogMural from '../../components/murals/BlogMural.astro';
import { categories } from '../../data/site';

export function getStaticPaths() {
	return categories.map((category) => ({
		params: { id: category.id },
		props: { category },
	}));
}

const { category } = Astro.props;
const posts = (
	await getCollection('blog', ({ data }) => !data.draft && data.category === category.id)
)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.map((p) => ({ id: p.id, title: p.data.title, category: category.label }));
---

<MuralLayout title={category.label}>
  <div class="mural-scroll">
    <svg class="mural-svg" viewBox="0 0 1200 180" xmlns="http://www.w3.org/2000/svg" style="margin-bottom: -1rem;">
      <rect width="1200" height="180" fill="#2a2f36" />
      <ellipse cx="200" cy="90" rx="120" ry="70" fill={category.color} opacity="0.2" />
      <text x="600" y="90" text-anchor="middle" font-family="Caveat, cursive" font-size="44" font-weight="700" fill="#ebe6dc">{category.label}</text>
      <text x="600" y="125" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="12" fill="rgba(235,230,220,0.5)">{category.description}</text>
      <a href="/categorias">
        <text x="60" y="50" font-family="Caveat, cursive" font-size="22" fill="rgba(235,230,220,0.5)">← temas</text>
      </a>
    </svg>
    <BlogMural posts={posts} />
  </div>
</MuralLayout>
