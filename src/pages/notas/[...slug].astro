---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermLine from '../../components/TermLine.astro';
import PromptCursor from '../../components/PromptCursor.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  const sorted = notes.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return sorted.map((note, i) => ({
    params: { slug: note.id },
    props: {
      note,
      prev: sorted[i + 1] ?? null,
      next: sorted[i - 1] ?? null,
    },
  }));
}

const { note, prev, next } = Astro.props;
const { Content } = await render(note);
const date = note.data.pubDate.toLocaleDateString('es-ES', {
  day: 'numeric', month: 'long', year: 'numeric',
});
---

<BaseLayout title={note.data.title} path="/notas">
  <TermLine cmd={`cat "${note.data.title}"`}>
    <p class="out out--lg">{note.data.title}</p>
    <p class="article__meta">{date}</p>
    <div class="article__body">
      <Content />
    </div>

    {(prev || next) && (
      <nav class="post-nav" aria-label="Notas">
        {prev ? (
          <a href={`/notas/${prev.id}`}>
            <div class="post-nav__l">← anterior</div>
            <p class="post-nav__t">{prev.data.title}</p>
          </a>
        ) : <div />}
        {next ? (
          <a class="next" href={`/notas/${next.id}`}>
            <div class="post-nav__l">siguiente →</div>
            <p class="post-nav__t">{next.data.title}</p>
          </a>
        ) : <div />}
      </nav>
    )}
  </TermLine>
  <PromptCursor />
</BaseLayout>
