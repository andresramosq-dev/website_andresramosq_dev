---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPath from '../../components/TermPath.astro';
import TermPanel from '../../components/TermPanel.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  const sorted = notes.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return sorted.map((note, i) => ({
    params: { slug: note.id },
    props: {
      note,
      prev: sorted[i + 1] ?? null,
      next: sorted[i - 1] ?? null,
    },
  }));
}

const { note, prev, next } = Astro.props;
const { Content } = await render(note);
const date = note.data.pubDate.toLocaleDateString('es-ES', {
  day: 'numeric', month: 'long', year: 'numeric',
});
const fullPath = `/notas/${note.id}`;
---

<BaseLayout title={note.data.title} path={fullPath}>
  <TermPath path={fullPath} />

  <TermPanel label={note.data.title}>
    <p class="article__meta">{date}</p>
    <div class="article__body">
      <Content />
    </div>

    {(prev || next) && (
      <nav class="post-nav" aria-label="Notas">
        {prev ? (
          <a href={`/notas/${prev.id}`}>
            <span class="post-nav__label">← anterior</span>
            <p class="post-nav__title">{prev.data.title}</p>
          </a>
        ) : <div />}
        {next ? (
          <a class="post-nav__next" href={`/notas/${next.id}`}>
            <span class="post-nav__label">siguiente →</span>
            <p class="post-nav__title">{next.data.title}</p>
          </a>
        ) : <div />}
      </nav>
    )}
  </TermPanel>
</BaseLayout>
