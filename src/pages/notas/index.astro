---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('notes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="notas" description="Notas cortas" path="/notas">
  <header class="pg-head">
    <p class="crumb"><a href="/">~</a> / notas</p>
    <h1 class="pg-title">Notas</h1>
    <p class="pg-desc">Ideas breves y pensamientos rápidos.</p>
  </header>

  <ul class="list">
    {
      notes.map((note) => (
        <li>
          <a href={`/notas/${note.id}`}>
            <p class="list__title">{note.data.title}</p>
            <p class="list__meta">
              {note.data.pubDate.toLocaleDateString('es-ES', {
                day: '2-digit',
                month: 'short',
                year: 'numeric',
              })}
            </p>
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>
