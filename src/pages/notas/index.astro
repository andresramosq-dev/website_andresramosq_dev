---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPath from '../../components/TermPath.astro';
import TermPanel from '../../components/TermPanel.astro';
import FeedList from '../../components/FeedList.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('notes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = (d: Date) => d.toLocaleDateString('es-ES', { month: 'short', year: 'numeric' });
---

<BaseLayout title="notas" path="/notas">
  <TermPath path="/notas" />

  <TermPanel label="notas/">
    <FeedList
      items={notes.map((n) => ({
        href: `/notas/${n.id}`,
        title: n.data.title,
        meta: fmt(n.data.pubDate),
      }))}
    />
  </TermPanel>
</BaseLayout>
