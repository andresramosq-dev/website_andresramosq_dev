---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import TermBlock from '../../components/TermBlock.astro';
import FeedList from '../../components/FeedList.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('notes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = (d: Date) => d.toLocaleDateString('es-ES', { month: 'short', year: 'numeric' });
---

<BaseLayout title="notas" path="/notas">
  <PageHeader segment="notas" title="Notas" />

  <TermBlock cmd="ls -la notas/">
    <FeedList
      items={notes.map((n) => ({
        href: `/notas/${n.id}`,
        title: `${n.id}.md`,
        meta: fmt(n.data.pubDate),
      }))}
    />
  </TermBlock>
</BaseLayout>
