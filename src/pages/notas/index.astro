---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermSection from '../../components/TermSection.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('notes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="notas" description="Notas cortas" path="/notas">
  <p class="crumb"><a href="/">~</a> / notas</p>
  <h1 class="pg-title">notas/</h1>
  <p class="pg-desc">Ideas breves y pensamientos rápidos.</p>

  <TermSection cmd={`ls notas/ (${notes.length})`}>
    <ul class="notes">
      {
        notes.map((note) => (
          <li>
            <a href={`/notas/${note.id}`}>
              <span class="notes__title">{note.data.title}</span>
              <span class="notes__date">
                {note.data.pubDate.toLocaleDateString('es-ES', {
                  day: '2-digit',
                  month: 'short',
                  year: 'numeric',
                })}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </TermSection>
</BaseLayout>
