---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CmdBlock from '../../components/CmdBlock.astro';
import WhoamiPanel from '../../components/WhoamiPanel.astro';
import BioPanel from '../../components/BioPanel.astro';
---

<BaseLayout title="about me" path="/about">
	<div class="console-session">
		<CmdBlock cmd="cat whoami.txt" cwd="~/about" transcript id="profile">
			<WhoamiPanel />
		</CmdBlock>

		<CmdBlock cmd="cat profile.txt" cwd="~/about" transcript id="bio">
			<BioPanel />
		</CmdBlock>
	</div>
</BaseLayout>
