---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ConsoleTitle from '../../components/ConsoleTitle.astro';
import CmdBlock from '../../components/CmdBlock.astro';
import ProfilePhoto from '../../components/ProfilePhoto.astro';
import { site, skills, now, principles } from '../../data/site';

const skillGroups = [
	{ dir: 'frontend', items: skills.frontend },
	{ dir: 'backend', items: skills.backend },
	{ dir: 'tools', items: skills.tools },
];
---

<BaseLayout title="sobre mí" path="/about">
  <ConsoleTitle route="/about" title="Andres Ramos" />

  <CmdBlock cmd="whoami" id="perfil">
    <div class="about-hero">
      <ProfilePhoto size="md" />
      <div class="about-hero__info">
        <p class="out-line out-line--name">{site.name}</p>
        <p class="out-line out-line--muted">{site.role}</p>
        <p class="out-line out-line--muted">{site.location} · desde {site.since}</p>
      </div>
    </div>
  </CmdBlock>

  <CmdBlock cmd="cat me.json" id="datos">
    <dl class="kv">
      <div><dt>"name"</dt><dd>{site.name}</dd></div>
      <div><dt>"role"</dt><dd>{site.role}</dd></div>
      <div><dt>"email"</dt><dd><a href={`mailto:${site.email}`}>{site.email}</a></dd></div>
      <div><dt>"github"</dt><dd><a href={site.links[0].href} target="_blank" rel="noreferrer">{site.handle}</a></dd></div>
      <div><dt>"web"</dt><dd>{site.domain}</dd></div>
    </dl>
  </CmdBlock>

  <CmdBlock cmd="cat bio.txt" id="bio">
    <div class="prose">
      <p class="prose__lead">{site.bio}</p>
      {site.about.map((p) => <p>{p}</p>)}
    </div>
  </CmdBlock>

  <CmdBlock cmd="cat now.txt" id="now">
    <dl class="now-grid">
      <div class="now-item">
        <dt>working_on</dt>
        <dd>{now.working}</dd>
      </div>
      <div class="now-item">
        <dt>learning</dt>
        <dd>{now.learning}</dd>
      </div>
      <div class="now-item">
        <dt>reading</dt>
        <dd>{now.reading}</dd>
      </div>
    </dl>
  </CmdBlock>

  <CmdBlock cmd="ls -la skills/" id="skills">
    <ul class="ls-out">
      {skillGroups.map((g) => (
        <li class="ls-out__dir">
          <span class="ls-out__perm">drwxr-xr-x</span>
          <span class="ls-out__name">{g.dir}/</span>
          <ul class="ls-out ls-out--nested">
            {g.items.map((s) => (
              <li>
                <span class="ls-out__perm">-rw-r--r--</span>
                <span class="ls-out__name">{s}</span>
              </li>
            ))}
          </ul>
        </li>
      ))}
    </ul>
  </CmdBlock>

  <CmdBlock cmd="cat principles.txt" id="principles">
    <div class="principles">
      {principles.map((p) => (
        <div class="principle">
          <p class="principle__title">{p.title}</p>
          <p class="principle__desc">{p.desc}</p>
        </div>
      ))}
    </div>
  </CmdBlock>

  <p class="cmd-block__line cmd-block__line--idle">
    <span class="cmd-block__user">{site.user}</span>@<span class="cmd-block__host">{site.domain}</span>:<span class="cmd-block__cwd">~/about</span><span class="cmd-block__sig">$</span>
    <span class="cursor" aria-hidden="true"></span>
  </p>
</BaseLayout>
