---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ConsoleTitle from '../../components/ConsoleTitle.astro';
import CmdBlock from '../../components/CmdBlock.astro';
import WhoamiPanel from '../../components/WhoamiPanel.astro';
import BioPanel from '../../components/BioPanel.astro';
import SitePanel from '../../components/SitePanel.astro';
import StackPanel from '../../components/StackPanel.astro';
import PhilosophyPanel from '../../components/PhilosophyPanel.astro';
import TastesPanel from '../../components/TastesPanel.astro';
import { site, now } from '../../data/site';
---

<BaseLayout title="about me" path="/about">
  <ConsoleTitle />

  <CmdBlock cmd="whoami" id="profile">
    <WhoamiPanel />
  </CmdBlock>

  <CmdBlock cmd="cat bio.txt" id="bio">
    <BioPanel />
  </CmdBlock>

  <CmdBlock cmd="cat now.txt" id="now">
    <dl class="now-grid">
      <div class="now-item">
        <dt>focused_on</dt>
        <dd>{now.focused_on}</dd>
      </div>
      <div class="now-item">
        <dt>looking_for</dt>
        <dd>{now.looking_for}</dd>
      </div>
      <div class="now-item">
        <dt>philosophy</dt>
        <dd>{now.philosophy}</dd>
      </div>
    </dl>
  </CmdBlock>

  <CmdBlock cmd="cat site.txt" id="site">
    <SitePanel />
  </CmdBlock>

  <CmdBlock cmd="cat philosophy.txt" id="philosophy">
    <PhilosophyPanel />
  </CmdBlock>

  <CmdBlock cmd="stack" id="stack">
    <StackPanel />
  </CmdBlock>

  <CmdBlock cmd="tastes" id="tastes">
    <TastesPanel />
  </CmdBlock>

  <p class="cmd-block__line cmd-block__line--idle">
    <span class="cmd-block__path">
      <span class="cmd-block__user">{site.consoleUser}</span>@<span class="cmd-block__host">{site.domain}</span><span class="cmd-block__colon">:</span><span class="cmd-block__cwd">~/about</span>
    </span>
    <span class="cmd-block__sig"> @</span>
    <span class="cursor" aria-hidden="true"></span>
  </p>
</BaseLayout>
