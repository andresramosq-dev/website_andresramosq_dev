---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ConsoleTitle from '../../components/ConsoleTitle.astro';
import CmdBlock from '../../components/CmdBlock.astro';
import WhoamiPanel from '../../components/WhoamiPanel.astro';
import BioPanel from '../../components/BioPanel.astro';
import { site, skills, now, principles } from '../../data/site';

const skillGroups = [
	{ dir: 'frontend', items: skills.frontend },
	{ dir: 'backend', items: skills.backend },
	{ dir: 'tools', items: skills.tools },
];
---

<BaseLayout title="about me" path="/about">
  <ConsoleTitle />

  <CmdBlock cmd="about me" id="perfil">
    <WhoamiPanel />
  </CmdBlock>

  <CmdBlock cmd="cat bio.txt" id="bio" plain>
    <BioPanel />
  </CmdBlock>

  <CmdBlock cmd="cat now.txt" id="now">
    <dl class="now-grid">
      <div class="now-item">
        <dt>working_on</dt>
        <dd>{now.working}</dd>
      </div>
      <div class="now-item">
        <dt>learning</dt>
        <dd>{now.learning}</dd>
      </div>
      <div class="now-item">
        <dt>reading</dt>
        <dd>{now.reading}</dd>
      </div>
    </dl>
  </CmdBlock>

  <CmdBlock cmd="ls -la skills/" id="skills">
    <ul class="ls-out">
      {skillGroups.map((g) => (
        <li class="ls-out__dir">
          <span class="ls-out__perm">drwxr-xr-x</span>
          <span class="ls-out__name">{g.dir}/</span>
          <ul class="ls-out ls-out--nested">
            {g.items.map((s) => (
              <li>
                <span class="ls-out__perm">-rw-r--r--</span>
                <span class="ls-out__name">{s}</span>
              </li>
            ))}
          </ul>
        </li>
      ))}
    </ul>
  </CmdBlock>

  <CmdBlock cmd="cat principles.txt" id="principles">
    <div class="principles">
      {principles.map((p) => (
        <div class="principle">
          <p class="principle__title">{p.title}</p>
          <p class="principle__desc">{p.desc}</p>
        </div>
      ))}
    </div>
  </CmdBlock>

  <p class="cmd-block__line cmd-block__line--idle">
    <span class="cmd-block__path">
      <span class="cmd-block__user">{site.consoleUser}</span>@<span class="cmd-block__host">{site.domain}</span>
    </span>
    <span class="cmd-block__sig"> @</span>
    <span class="cursor" aria-hidden="true"></span>
  </p>
</BaseLayout>
