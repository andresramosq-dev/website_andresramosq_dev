---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import TermBlock from '../../components/TermBlock.astro';
import { experience } from '../../data/site';
---

<BaseLayout title="experiencia" path="/experiencia">
  <PageHeader segment="experiencia" title="Experiencia" />

  <TermBlock cmd="cat experiencia.log">
    {experience.map((job) => (
      <article class="exp">
        <h2 class="exp__role">{job.role}</h2>
        <p class="exp__meta">{job.company} · {job.period}</p>
        <p class="exp__desc">{job.desc}</p>
      </article>
    ))}
  </TermBlock>
</BaseLayout>
