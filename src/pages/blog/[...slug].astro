---
import BaseLayout from '../../layouts/BaseLayout.astro';
import IdeaNode from '../../components/IdeaNode.astro';
import { getCollection, render } from 'astro:content';
import { categoryLabel, categories } from '../../data/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const catIcon = categories.find((c) => c.id === post.data.category)?.icon ?? 'pen';
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="board-article">
    <a class="board-back" href="/blog">← volver al muro</a>

    <div class="board-article__node">
      <IdeaNode
        title={post.data.title}
        subtitle={post.data.description}
        icon={catIcon}
        size="md"
        frame={3}
      />
      <p class="board-article__meta">
        {categoryLabel[post.data.category]} ·{' '}
        {post.data.pubDate.toLocaleDateString('es-ES', {
          day: 'numeric',
          month: 'long',
          year: 'numeric',
        })}{' '}
        · {post.data.minutes} min
      </p>
    </div>

    <div class="board-read">
      <div class="board-prose">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>
