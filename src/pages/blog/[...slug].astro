---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArtIllus from '../../components/ArtIllus.astro';
import { getCollection, render } from 'astro:content';
import { categoryLabel } from '../../data/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="article">
    <a class="back" href="/blog">← Blog</a>
    <div class="article__art">
      <ArtIllus variant={post.data.category} />
    </div>
    <p class="article__label">{categoryLabel[post.data.category]}</p>
    <h1 class="article__title">{post.data.title}</h1>
    <div class="article__meta">
      <time datetime={post.data.pubDate.toISOString()}>
        {post.data.pubDate.toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' })}
      </time>
      · {post.data.minutes} min
    </div>
    <div class="article__body"><Content /></div>
  </article>
</BaseLayout>
