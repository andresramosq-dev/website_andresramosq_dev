---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermLine from '../../components/TermLine.astro';
import PromptCursor from '../../components/PromptCursor.astro';
import { getCollection, render } from 'astro:content';
import { categoryLabel } from '../../data/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const sorted = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return sorted.map((post, i) => ({
    params: { slug: post.id },
    props: { post, prev: sorted[i + 1] ?? null, next: sorted[i - 1] ?? null },
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
const date = post.data.pubDate.toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' });
---

<BaseLayout title={post.data.title} description={post.data.description} path="/blog">
  <TermLine cmd={`cat "${post.data.title}"`}>
    <p class="out out--lg">{post.data.title}</p>
    <p class="article__meta">{date} · {categoryLabel[post.data.category]}</p>
    <div class="article__body"><Content /></div>

    {(prev || next) && (
      <nav class="post-nav">
        {prev ? (
          <a href={`/blog/${prev.id}`}>
            <div class="post-nav__l">← anterior</div>
            <p class="post-nav__t">{prev.data.title}</p>
          </a>
        ) : <div />}
        {next ? (
          <a class="next" href={`/blog/${next.id}`}>
            <div class="post-nav__l">siguiente →</div>
            <p class="post-nav__t">{next.data.title}</p>
          </a>
        ) : <div />}
      </nav>
    )}
  </TermLine>
  <PromptCursor />
</BaseLayout>
