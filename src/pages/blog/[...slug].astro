---
import BaseLayout from '../../layouts/BaseLayout.astro';
import IdeaNode from '../../components/IdeaNode.astro';
import { getCollection, render } from 'astro:content';
import { categoryLabel, categoryColor, categories } from '../../data/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const cat = categories.find((c) => c.id === post.data.category)!;
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="art-article">
    <a class="art-back" href="/blog">← muro de escritos</a>

    <IdeaNode
      title={post.data.title}
      subtitle={categoryLabel[post.data.category]}
      desc={post.data.description}
      icon={cat.icon}
      color={categoryColor[post.data.category]}
      size="md"
      frame={3}
    />

    <p class="art-meta">
      {post.data.pubDate.toLocaleDateString('es-ES', {
        day: 'numeric',
        month: 'long',
        year: 'numeric',
      })}{' '}
      · {post.data.minutes} min
    </p>

    <div class="art-paper">
      <div class="art-prose">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>
