---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryDot from '../../components/CategoryDot.astro';
import { getCollection, render } from 'astro:content';
import { categoryLabel } from '../../data/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const sorted = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return sorted.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: sorted[i + 1] ?? null,
      next: sorted[i - 1] ?? null,
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description} path="/blog">
  <article class="article">
    <p class="crumb">
      <a href="/">~</a> / <a href="/blog">blog</a> / {post.id}
    </p>
    <h1 class="pg-title">{post.data.title}</h1>
    <p class="article__meta">
      <CategoryDot category={post.data.category} />
      {categoryLabel[post.data.category]} ·{' '}
      {post.data.pubDate.toLocaleDateString('es-ES', {
        day: 'numeric',
        month: 'long',
        year: 'numeric',
      })}{' '}
      · {post.data.minutes} min read
    </p>
    <div class="article__body">
      <Content />
    </div>

  {(prev || next) && (
    <nav class="post-nav" aria-label="Navegación entre artículos">
      {prev ? (
        <a href={`/blog/${prev.id}`}>
          <span class="post-nav__label">← anterior</span>
          <p class="post-nav__title">{prev.data.title}</p>
        </a>
      ) : <div />}
      {next ? (
        <a class="post-nav__next" href={`/blog/${next.id}`}>
          <span class="post-nav__label">siguiente →</span>
          <p class="post-nav__title">{next.data.title}</p>
        </a>
      ) : <div />}
    </nav>
  )}
  </article>
</BaseLayout>
