---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostTile from '../../components/PostTile.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const [featured, ...rest] = posts;
---

<BaseLayout title="Blog">
  <div class="wrap">
    <header class="pg-head">
      <h1>Blog</h1>
      <p>Artículos sobre diseño, código y oficio.</p>
    </header>
    <div class="post-grid">
      {featured && (
        <PostTile
          href={`/blog/${featured.id}`}
          title={featured.data.title}
          description={featured.data.description}
          date={featured.data.pubDate}
          minutes={featured.data.minutes}
          category={featured.data.category}
          featured
        />
      )}
      {rest.map((post) => (
        <PostTile
          href={`/blog/${post.id}`}
          title={post.data.title}
          description={post.data.description}
          date={post.data.pubDate}
          minutes={post.data.minutes}
          category={post.data.category}
        />
      ))}
    </div>
  </div>
</BaseLayout>
