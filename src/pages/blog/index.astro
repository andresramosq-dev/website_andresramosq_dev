---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import TermBlock from '../../components/TermBlock.astro';
import FeedList from '../../components/FeedList.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = (d: Date) => d.toLocaleDateString('es-ES', { month: 'short', year: 'numeric' });
---

<BaseLayout title="blog" path="/blog">
  <PageHeader segment="blog" title="Blog" />

  <TermBlock cmd="ls blog/">
    <FeedList
      items={posts.map((p) => ({
        href: `/blog/${p.id}`,
        title: p.data.title,
        meta: fmt(p.data.pubDate),
      }))}
    />
  </TermBlock>
</BaseLayout>
