---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { categoryLabel } from '../../data/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Escritos" description="Artículos del blog">
  <div class="chalk-page">
    <header class="chalk-page-head">
      <p class="chalk-page-kicker">pizarra</p>
      <h1 class="chalk-page-title">Escritos</h1>
      <p class="chalk-page-lead">Notas sueltas sobre diseño, código y oficio — como si estuvieran escritas a tiza.</p>
    </header>

    <div class="chalk-stream">
      {
        posts.map((post) => (
          <article class="chalk-item">
            <div class="chalk-item-meta">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('es-ES', {
                  day: 'numeric',
                  month: 'long',
                  year: 'numeric',
                })}
              </time>
              <span>{categoryLabel[post.data.category]}</span>
              <span>{post.data.minutes} min</span>
            </div>
            <h2 class="chalk-item-title">
              <a href={`/blog/${post.id}`}>{post.data.title}</a>
            </h2>
            <p class="chalk-item-desc">{post.data.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</BaseLayout>
