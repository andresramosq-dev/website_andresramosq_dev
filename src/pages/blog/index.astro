---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { categories } from '../../data/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const stripArt: Record<string, string> = {
	diseno: '/images/strips/strip-diseno.svg',
	codigo: '/images/strips/strip-codigo.svg',
	oficio: '/images/strips/strip-oficio.svg',
	metodo: '/images/strips/strip-metodo.svg',
};
---

<BaseLayout title="Escritos" description="Muro de escritos del blog." currentPath="/blog" mural>
	<header class="page-head">
		<p class="hero__kicker">muro de escritos</p>
		<h1>Blog</h1>
		<p>Cada pieza es un dibujo de tiza + una nota. No es una lista de tarjetas.</p>
	</header>

	<div class="strips">
		{
			posts.map((post) => {
				const cat = categories.find((item) => item.id === post.data.category);
				return (
					<a class="strip" href={`/blog/${post.id}`}>
						<div class="strip__art">
							<img
								src={stripArt[post.data.category]}
								alt=""
								width="420"
								height="320"
							/>
						</div>
						<div class="strip__body">
							<p class="strip__label">{cat?.label ?? post.data.category}</p>
							<h2 class="strip__title">{post.data.title}</h2>
							<p class="strip__text">{post.data.description}</p>
							<p class="strip__meta">
								{post.data.pubDate.toLocaleDateString('es-ES', {
									year: 'numeric',
									month: 'short',
									day: 'numeric',
								})}
								{' · '}
								{post.data.minutes} min
							</p>
						</div>
					</a>
				);
			})
		}
	</div>
</BaseLayout>
