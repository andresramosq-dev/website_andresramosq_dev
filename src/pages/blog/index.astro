---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout
	title="Blog"
	description="Notas técnicas y de oficio en Markdown."
	currentPath="/blog"
>
	<section class="section" style="margin-top: 0.85rem;" aria-labelledby="blog-index-title">
		<p class="section__kicker"># archivo</p>
		<h1 class="page-title" id="blog-index-title">Blog</h1>
		<p class="page-deck">
			Cada entrada es un archivo Markdown en <code>src/content/blog/</code>.
			Así se versiona, se revisa y se publica sin CMS.
		</p>
		<div class="entry-list">
			{
				posts.map((post) => (
					<article class="entry">
						<p class="entry__meta">
							{post.data.section} ·{' '}
							{post.data.pubDate.toLocaleDateString('es-ES', {
								year: 'numeric',
								month: 'short',
								day: 'numeric',
							})}
						</p>
						<h2 class="entry__title">
							<a href={`/blog/${post.id}`}>{post.data.title}</a>
						</h2>
						<p class="entry__desc">{post.data.description}</p>
					</article>
				))
			}
		</div>
	</section>
</BaseLayout>
