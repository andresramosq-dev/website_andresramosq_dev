---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryDot from '../../components/CategoryDot.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="blog" description="Artículos" path="/blog">
  <header class="pg-head">
    <p class="crumb"><a href="/">~</a> / blog</p>
    <h1 class="pg-title">Blog</h1>
    <p class="pg-desc">{posts.length} artículos sobre diseño, código y oficio.</p>
  </header>

  <ul class="posts">
    {
      posts.map((post) => (
        <li>
          <a href={`/blog/${post.id}`}>
            <span class="posts__date">
              {post.data.pubDate.toLocaleDateString('es-ES', {
                day: '2-digit',
                month: 'short',
                year: 'numeric',
              })}
            </span>
            <span class="posts__title">
              <CategoryDot category={post.data.category} />
              {post.data.title}
            </span>
            <span class="posts__tag">{post.data.minutes} min</span>
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>
