---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { categories } from '../../data/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const label = (id: string) => categories.find((item) => item.id === id)?.label ?? id;
---

<BaseLayout title="Escritos" description="Archivo del blog." currentPath="/blog">
	<header class="page-head">
		<h1>Escritos</h1>
		<p>Notas ordenadas por fecha. Tipografía primero, sin tarjetas.</p>
	</header>

	<section class="writing" style="border-top: 0; padding-top: 0;">
		{
			posts.map((post) => (
				<a class="entry" href={`/blog/${post.id}`}>
					<span class="entry__date">
						{post.data.pubDate.toLocaleDateString('es-ES', {
							year: 'numeric',
							month: 'short',
							day: 'numeric',
						})}
					</span>
					<span class="entry__title">{post.data.title}</span>
					<span class="entry__cat">{label(post.data.category)}</span>
					<span class="entry__desc">{post.data.description}</span>
				</a>
			))
		}
	</section>
</BaseLayout>
