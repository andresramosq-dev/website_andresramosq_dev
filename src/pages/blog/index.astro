---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermLine from '../../components/TermLine.astro';
import PromptCursor from '../../components/PromptCursor.astro';
import FeedList from '../../components/FeedList.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = (d: Date) => d.toLocaleDateString('es-ES', { month: 'short', year: 'numeric' });
---

<BaseLayout title="blog" path="/blog">
  <TermLine cmd="ls blog/">
    <FeedList
      items={posts.map((p) => ({
        href: `/blog/${p.id}`,
        title: p.data.title,
        meta: fmt(p.data.pubDate),
      }))}
    />
  </TermLine>
  <PromptCursor />
</BaseLayout>
