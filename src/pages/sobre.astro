---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermLine from '../components/TermLine.astro';
import PromptCursor from '../components/PromptCursor.astro';
import FeedList from '../components/FeedList.astro';
import ProfilePhoto from '../components/ProfilePhoto.astro';
import { site, skills, now, experience } from '../data/site';
---

<BaseLayout title="sobre" path="/sobre">
  <div class="hero">
    <ProfilePhoto size="sm" />
    <div>
      <TermLine cmd="whoami">
        <p class="out out--lg">{site.name}</p>
        <p class="out out--sm">{site.role} · {site.location}</p>
      </TermLine>
    </div>
  </div>

  <TermLine cmd="cat me.json">
    <pre class="pre">{`{
  "name": "${site.name}",
  "role": "${site.role}",
  "since": ${site.since},
  "email": "${site.email}",
  "web": "${site.domain}"
}`}</pre>
  </TermLine>

  <TermLine cmd="cat bio.txt">
  {site.about.map((p) => <p class="out">{p}</p>)}
  </TermLine>

  <TermLine cmd="cat now.txt">
    <dl class="now">
      <div><dt>working_on</dt><dd>{now.working}</dd></div>
      <div><dt>learning</dt><dd>{now.learning}</dd></div>
      <div><dt>reading</dt><dd>{now.reading}</dd></div>
    </dl>
  </TermLine>

  <TermLine cmd="ls skills/">
    <p class="skills">{skills.join('  ')}</p>
  </TermLine>

  <TermLine cmd="cat jobs.log">
    <ul class="jobs">
      {experience.map((job) => (
        <li>
          <div class="jobs__head">
            <span class="jobs__role">{job.role}</span>
            <span class="jobs__when">{job.period}</span>
          </div>
          <p class="jobs__sub">{job.company} — {job.desc}</p>
        </li>
      ))}
    </ul>
  </TermLine>

  <TermLine cmd="cat links.txt">
    <p class="out">
      <a href={site.links[0].href}>{site.handle}</a>
      {' · '}
      <a href={`mailto:${site.email}`}>{site.email}</a>
      {' · '}
      <a href="/blog">./blog</a>
      {' · '}
      <a href="/proyectos">./proyectos</a>
    </p>
  </TermLine>

  <PromptCursor />
</BaseLayout>
