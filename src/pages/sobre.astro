---
import BaseLayout from '../layouts/BaseLayout.astro';
import IdeaNode from '../components/IdeaNode.astro';
import { site } from '../data/site';
---

<BaseLayout title="Sobre" description="Sobre el autor del blog">
  <section class="board-section">
    <div style="max-width: 420px; margin-bottom: 2rem; transform: rotate(-1deg);">
      <IdeaNode title="Sobre mí" subtitle={site.role} icon="user" size="lg" frame={2} />
    </div>

    <div class="board-read">
      <div class="board-prose">
        <p>
          Soy <strong>{site.name}</strong>. {site.bio}
        </p>
        <p>
          Este sitio es una pizarra de ideas: notas sueltas, conectadas, con dibujos e iconos — no un
          blog de plantilla.
        </p>
        <p>
          Explora los <a href="/blog">escritos</a> o mira los <a href="/proyectos">proyectos</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
