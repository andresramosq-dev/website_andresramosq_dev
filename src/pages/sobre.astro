---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArtIcon from '../components/ArtIcon.astro';
import { site } from '../data/site';
---

<BaseLayout title="Sobre" description="Sobre el autor del blog">
  <div class="wrap">
    <header class="page-head">
      <h1>Sobre mí</h1>
    </header>

    <div class="about-box">
      <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.25rem;">
        <ArtIcon name="user" color="#e07a5f" size="lg" />
        <div>
          <p style="margin:0;font-weight:700;font-size:1.1rem;">{site.name}</p>
          <p style="margin:0;color:var(--muted);font-size:0.9rem;">{site.role}</p>
        </div>
      </div>
      <p>{site.bio}</p>
      <p>
        {
          site.links.map((link) => (
            <a href={link.href} style="margin-right:1rem;">{link.label}</a>
          ))
        }
      </p>
    </div>
  </div>
</BaseLayout>
