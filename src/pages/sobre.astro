---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArtIllus from '../components/ArtIllus.astro';
import { site } from '../data/site';
---

<BaseLayout title="Sobre">
  <div class="wrap">
    <header class="pg-head"><h1>Sobre mí</h1></header>
    <div style="display:grid;grid-template-columns:100px 1fr;gap:1.5rem;max-width:var(--read);align-items:start;">
      <ArtIllus variant="oficio" />
      <div>
        <h2 style="font-family:var(--display);font-size:1.35rem;font-weight:700;margin:0 0 0.25rem;">{site.name}</h2>
        <p style="color:var(--muted);margin:0 0 1rem;">{site.role}</p>
        <p style="margin:0 0 1rem;line-height:1.7;">{site.bio}</p>
        <p>{site.links.map((l) => <a href={l.href} style="margin-right:1rem;color:var(--ink);">{l.label}</a>)}</p>
      </div>
    </div>
  </div>
</BaseLayout>
