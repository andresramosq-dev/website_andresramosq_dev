---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
---

<BaseLayout title="Sobre" description={site.bio} currentPath="/sobre">
	<header class="page-head">
		<h1>{site.name}</h1>
		<p>{site.bio}</p>
	</header>

	<div class="about-block">
		<img src="/images/art-mark.svg" alt="" width="120" height="120" style="margin-bottom: 1rem;" />
		<ul class="about-meta">
			<li>
				<span>Rol</span>
				<strong>{site.role}</strong>
			</li>
			<li>
				<span>Ubicación</span>
				<strong>{site.location}</strong>
			</li>
			<li>
				<span>Contacto</span>
				<strong>
					{
						site.links.map((link, i) => (
							<span>
								{i > 0 ? ' · ' : ''}
								<a class="link-plain" href={link.href}>
									{link.label}
								</a>
							</span>
						))
					}
				</strong>
			</li>
		</ul>
	</div>
</BaseLayout>
