---
import BaseLayout from '../layouts/BaseLayout.astro';
import Terminal from '../components/Terminal.astro';
import ProfilePhoto from '../components/ProfilePhoto.astro';
import TermSection from '../components/TermSection.astro';
import { site, skills, timeline, now, principles } from '../data/site';
---

<BaseLayout title="sobre" path="/sobre">
  <p class="crumb"><a href="/">~</a> / sobre</p>

  <div class="about-top">
    <ProfilePhoto size="sm" />
    <div class="about-top__text">
      <h1 class="pg-title">{site.name}</h1>
      <p class="pg-desc">{site.tagline}</p>
    </div>
  </div>

  <Terminal title="~/sobre/me.json">
    <p class="term__line"><span class="term__prompt">$ </span><span class="term__cmd">cat me.json</span></p>
    <p class="term__out term__out--muted">
      {'{'}
      <br />
      &nbsp;&nbsp;"name": "{site.name}",<br />
      &nbsp;&nbsp;"role": "{site.role}",<br />
      &nbsp;&nbsp;"location": "{site.location}",<br />
      &nbsp;&nbsp;"since": {site.since},<br />
      &nbsp;&nbsp;"email": "{site.email}"<br />
      {'}'}
    </p>
  </Terminal>

  <TermSection cmd="cat bio.txt">
    {site.about.map((p) => (
      <p style="margin:0 0 0.85rem;line-height:1.75;font-size:0.82rem">{p}</p>
    ))}
  </TermSection>

  <TermSection cmd="cat now.txt">
    <div class="now">
      <dl>
        <div><dt>working_on</dt><dd>{now.working}</dd></div>
        <div><dt>learning</dt><dd>{now.learning}</dd></div>
        <div><dt>reading</dt><dd>{now.reading}</dd></div>
      </dl>
    </div>
  </TermSection>

  <TermSection cmd="ls skills/">
    <div class="tags">
      {skills.map((s) => <span class="tag tag--skill">{s}</span>)}
    </div>
  </TermSection>

  <TermSection cmd="cat principles.txt">
    <ul class="term-list">
      {principles.map((p) => (
        <li><strong>{p.title}</strong> — <span>{p.desc}</span></li>
      ))}
    </ul>
  </TermSection>

  <TermSection cmd="cat timeline.log">
    <ul class="timeline">
      {timeline.map((t) => (
        <li>
          <span class="timeline__year">{t.year}</span>
          <div>
            <p class="timeline__title">{t.title}</p>
            <p class="timeline__desc">{t.desc}</p>
          </div>
        </li>
      ))}
    </ul>
  </TermSection>

  <TermSection cmd="cat contact.txt">
    <div class="tags">
      {site.links.map((l) => (
        <a class="tag" href={l.href}>{l.label}</a>
      ))}
      <a class="tag" href="/blog">blog</a>
      <a class="tag" href="/notas">notas</a>
      <a class="tag" href="/proyectos">proyectos</a>
    </div>
  </TermSection>
</BaseLayout>
