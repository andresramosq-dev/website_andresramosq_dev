---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { site, techTimeline, music } from '../data/site';
---

<BaseLayout title="Sobre" description={site.bio} currentPath="/sobre">
	<header class="page-head">
		<p class="intro__label"><Icon name="user" size={16} /> Sobre</p>
		<h1>{site.name}</h1>
		<p class="about-lead">{site.bio}</p>
	</header>

	<div class="about-block">
		<div class="about-panel">
			<ul class="about-meta">
				<li>
					<span>Rol</span>
					<strong>{site.role}</strong>
				</li>
				<li>
					<span>Ubicación</span>
					<strong>{site.location}</strong>
				</li>
				<li>
					<span>Contacto</span>
					<strong>
						{
							site.links.map((link, i) => (
								<span>
									{i > 0 ? ' · ' : ''}
									<a href={link.href}>{link.label}</a>
								</span>
							))
						}
					</strong>
				</li>
			</ul>
		</div>

		<section class="about-panel" aria-labelledby="stack-title">
			<h2 class="section__title" id="stack-title">Stack en el tiempo</h2>
			<div class="timeline">
				{
					techTimeline.map((row) => (
						<div class="timeline__row">
							<div class="timeline__period">{row.period}</div>
							<div>
								<h3 class="timeline__title">{row.title}</h3>
								<p class="timeline__items">{row.items.join(' · ')}</p>
							</div>
						</div>
					))
				}
			</div>
		</section>

		<section class="about-panel" aria-labelledby="music-title">
			<h2 class="section__title" id="music-title">
				<Icon name="music" size={18} />
				Música
			</h2>
			<ul class="music-simple">
				{
					music.map((item) => (
						<li>
							<strong>{item.title}</strong>
							<span>{item.artist}</span>
						</li>
					))
				}
			</ul>
		</section>
	</div>
</BaseLayout>
