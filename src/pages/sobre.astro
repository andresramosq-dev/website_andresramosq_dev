---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import TermBlock from '../components/TermBlock.astro';
import ProfilePhoto from '../components/ProfilePhoto.astro';
import { site, skills, timeline } from '../data/site';
---

<BaseLayout title="sobre" path="/sobre">
  <PageHeader segment="sobre" title="Sobre mí" />

  <TermBlock cmd="cat bio.txt">
    <div class="about-row">
      <ProfilePhoto size="sm" />
      <div class="about-text">
        <p>{site.about[0]}</p>
        <p>{site.about[1]}</p>
      </div>
    </div>
  </TermBlock>

  <TermBlock cmd="ls skills/">
    <p class="skills-line">
      {skills.map((s) => <span>{s}</span>)}
    </p>
  </TermBlock>

  <TermBlock cmd="cat timeline.log">
    <ul class="timeline">
      {timeline.map((t) => (
        <li>
          <span class="timeline__year">{t.year}</span>
          <div>
            <p class="timeline__title">{t.title}</p>
            <p class="timeline__desc">{t.desc}</p>
          </div>
        </li>
      ))}
    </ul>
    <a class="mt-link" href="/experiencia">cd experiencia/ →</a>
  </TermBlock>
</BaseLayout>
