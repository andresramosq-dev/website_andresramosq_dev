---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import TermBlock from '../components/TermBlock.astro';
import ProfilePhoto from '../components/ProfilePhoto.astro';
import { site, skills, timeline, now, principles, experience } from '../data/site';
---

<BaseLayout title="sobre" path="/sobre">
  <PageHeader segment="sobre" title="Sobre mí" />

  <div class="about-layout">
    <aside class="about-side">
      <div class="panel panel--side">
        <ProfilePhoto size="md" />
        <dl class="about-meta">
          <dt>name</dt>
          <dd>{site.name}</dd>
          <dt>role</dt>
          <dd>{site.role}</dd>
          <dt>location</dt>
          <dd>{site.location}</dd>
          <dt>since</dt>
          <dd>{site.since}</dd>
          <dt>email</dt>
          <dd><a href={`mailto:${site.email}`}>{site.email}</a></dd>
          <dt>github</dt>
          <dd><a href={site.links[0].href} target="_blank" rel="noreferrer">{site.handle}</a></dd>
        </dl>
      </div>
    </aside>

    <div class="about-main">
      <TermBlock cmd="cat bio.txt">
        <div class="about-text">
          {site.about.map((p) => <p>{p}</p>)}
        </div>
      </TermBlock>

      <TermBlock cmd="cat now.txt">
        <dl class="now-grid">
          <div class="now-item">
            <dt>working_on</dt>
            <dd>{now.working}</dd>
          </div>
          <div class="now-item">
            <dt>learning</dt>
            <dd>{now.learning}</dd>
          </div>
          <div class="now-item">
            <dt>reading</dt>
            <dd>{now.reading}</dd>
          </div>
        </dl>
      </TermBlock>

      <TermBlock cmd="ls skills/">
        <p class="skills-line">
          {skills.map((s) => <span>{s}</span>)}
        </p>
      </TermBlock>

      <div class="about-split">
        <TermBlock cmd="cat principles.txt">
          <div class="principles">
            {principles.map((p) => (
              <div class="principle">
                <p class="principle__title">{p.title}</p>
                <p class="principle__desc">{p.desc}</p>
              </div>
            ))}
          </div>
        </TermBlock>

        <TermBlock cmd="cat timeline.log">
          <ul class="timeline">
            {timeline.map((t) => (
              <li>
                <span class="timeline__year">{t.year}</span>
                <div>
                  <p class="timeline__title">{t.title}</p>
                  <p class="timeline__desc">{t.desc}</p>
                </div>
              </li>
            ))}
          </ul>
        </TermBlock>
      </div>

      <TermBlock cmd="cat experiencia.log">
        <div class="exp-grid">
          {experience.map((job) => (
            <article class="exp">
              <h2 class="exp__role">{job.role}</h2>
              <p class="exp__meta">{job.company} · {job.period}</p>
              <p class="exp__desc">{job.desc}</p>
            </article>
          ))}
        </div>
      </TermBlock>
    </div>
  </div>
</BaseLayout>
