---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProfilePhoto from '../components/ProfilePhoto.astro';
import { site, skills, timeline } from '../data/site';
---

<BaseLayout title="sobre" path="/sobre">
  <header class="pg-head">
    <p class="crumb"><a href="/">~</a> / sobre</p>
    <h1 class="pg-title">Sobre mí</h1>
    <p class="pg-desc">{site.tagline}</p>
  </header>

  <div class="about-row">
    <ProfilePhoto size="sm" />
    <div class="about-text">
      {site.about.map((p) => <p>{p}</p>)}
    </div>
  </div>

  <section class="panel" style="margin-bottom:1.25rem">
    <h2 class="panel__title" style="margin-bottom:0.85rem">ls skills/</h2>
    <div class="tags">
      {skills.map((s) => <span class="tag">{s}</span>)}
    </div>
  </section>

  <section class="panel">
    <h2 class="panel__title" style="margin-bottom:0.85rem">cat timeline.log</h2>
    <ul class="timeline">
      {timeline.map((t) => (
        <li>
          <span class="timeline__year">{t.year}</span>
          <div>
            <p class="timeline__title">{t.title}</p>
            <p class="timeline__desc">{t.desc}</p>
          </div>
        </li>
      ))}
    </ul>
  </section>

  <p style="margin-top:1.5rem;font-size:0.9rem">
    <a href="/experiencia">Ver experiencia completa →</a>
  </p>
</BaseLayout>
