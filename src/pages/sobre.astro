---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { site } from '../data/site';
---

<BaseLayout title="Sobre" description="Sobre el autor del blog">
  <header class="page-head">
    <p class="page-head__kicker">// about</p>
    <h1 class="page-head__title">Sobre mí</h1>
  </header>

  <div class="blog-wrap" style="max-width: var(--read);">
    <div class="about-panel">
      <p>
        <strong>{site.name}</strong> — {site.role}. {site.bio}
      </p>
      <p>
        Este blog combina un mapa de ideas artístico en la portada con escritos sobre diseño, código y
        oficio. Tipografía de desarrollador, colores planos, iconos y SVG.
      </p>
      <p>
        Lee los <a href="/blog">escritos</a> o explora los <a href="/proyectos">proyectos</a>.
      </p>
    </div>

    <div class="topic-grid" style="margin-top: 1.5rem;">
      {
        site.links.map((link) => (
          <a class="topic-tile" href={link.href} style="--tile-color: var(--cyan)">
            <span class="topic-tile__icon">
              <Icon name={link.label === 'GitHub' ? 'code' : 'mail'} size={20} />
            </span>
            <div>
              <p class="topic-tile__label">{link.label}</p>
              <p class="topic-tile__desc">{link.href.replace('mailto:', '')}</p>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</BaseLayout>
