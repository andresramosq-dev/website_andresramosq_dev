---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
---

<BaseLayout title="Sobre" description="Sobre el autor del blog">
  <div class="chalk-page">
    <header class="chalk-page-head">
      <p class="chalk-page-kicker">sobre</p>
      <h1 class="chalk-page-title">Quién escribe</h1>
    </header>

    <div class="chalk-paper chalk-paper--about">
      <div class="chalk-prose">
        <p>
          Soy <strong>{site.name}</strong>. Este sitio es un blog artístico: una pizarra donde dejo
          notas sobre diseño, código y oficio — con tiza, dibujos y composición libre.
        </p>
        <p>
          No es una plantilla de tarjetas ni un diario corporativo. Es un lienzo donde el contenido
          importa tanto como la forma en que se presenta.
        </p>
        <p>
          Si quieres leer, empieza por los <a href="/blog">escritos</a> o explora los{' '}
          <a href="/proyectos">proyectos</a>.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
