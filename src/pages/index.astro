---
import MuralLayout from '../layouts/MuralLayout.astro';
import HomeMural from '../components/murals/HomeMural.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3)
  .map((p) => ({ id: p.id, title: p.data.title }));
---

<MuralLayout bare>
  <div class="mural-stage">
    <HomeMural recentPosts={posts} />
  </div>
</MuralLayout>
