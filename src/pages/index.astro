---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermLine from '../components/TermLine.astro';
import PromptCursor from '../components/PromptCursor.astro';
import FeedList from '../components/FeedList.astro';
import ProfilePhoto from '../components/ProfilePhoto.astro';
import { getCollection } from 'astro:content';
import { site, skills } from '../data/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const projects = (await getCollection('projects'))
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3);

const recent = posts.slice(0, 4);
const fmt = (d: Date) => d.toLocaleDateString('es-ES', { month: 'short', year: 'numeric' });
---

<BaseLayout path="/">
  <div class="hero">
    <ProfilePhoto size="sm" />
    <div>
      <TermLine cmd="whoami">
        <p class="out out--lg">{site.name}</p>
        <p class="out out--sm">{site.role}</p>
      </TermLine>
    </div>
  </div>

  <TermLine cmd="cat about.txt">
    <p class="out">{site.bio}</p>
  </TermLine>

  <TermLine cmd="ls skills/">
    <p class="skills">{skills.join('  ')}</p>
  </TermLine>

  <TermLine cmd="ls blog/">
    <FeedList
      items={recent.map((p) => ({
        href: `/blog/${p.id}`,
        title: p.data.title,
        meta: fmt(p.data.pubDate),
      }))}
    />
    <a class="mt" href="/blog">./blog →</a>
  </TermLine>

  <TermLine cmd="ls proyectos/">
    <FeedList
      items={projects.map((p) => ({
        href: `/proyectos/${p.id}`,
        title: p.data.title,
        meta: String(p.data.year),
      }))}
    />
    <a class="mt" href="/proyectos">./proyectos →</a>
  </TermLine>

  <PromptCursor />
</BaseLayout>
