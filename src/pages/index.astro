---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermPath from '../components/TermPath.astro';
import TermPanel from '../components/TermPanel.astro';
import TermTree from '../components/TermTree.astro';
import FeedList from '../components/FeedList.astro';
import ProfilePhoto from '../components/ProfilePhoto.astro';
import { getCollection } from 'astro:content';
import { site } from '../data/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const projects = (await getCollection('projects'))
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3);

const recent = posts.slice(0, 3);
const fmt = (d: Date) => d.toLocaleDateString('es-ES', { month: 'short', year: 'numeric' });
---

<BaseLayout path="/">
  <TermPath path="/" />

  <TermPanel label="welcome.txt">
    <div class="hero-compact">
      <ProfilePhoto size="sm" />
      <div>
        <p class="hero-compact__name">{site.name}</p>
        <p class="hero-compact__role">{site.role}</p>
        <p class="hero-compact__bio">{site.bio}</p>
      </div>
    </div>
  </TermPanel>

  <TermPanel label="tree">
    <TermTree />
  </TermPanel>

  <div class="home-grid">
    <TermPanel label="blog/">
      <FeedList
        items={recent.map((p) => ({
          href: `/blog/${p.id}`,
          title: p.data.title,
          meta: fmt(p.data.pubDate),
        }))}
      />
      <a class="mt-link" href="/blog">~/blog →</a>
    </TermPanel>

    <TermPanel label="proyectos/">
      <FeedList
        items={projects.map((p) => ({
          href: `/proyectos/${p.id}`,
          title: p.data.title,
          meta: String(p.data.year),
        }))}
        dir
      />
      <a class="mt-link" href="/proyectos">~/proyectos →</a>
    </TermPanel>
  </div>
</BaseLayout>
