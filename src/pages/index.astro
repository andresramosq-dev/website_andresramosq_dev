---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermBlock from '../components/TermBlock.astro';
import FeedList from '../components/FeedList.astro';
import ProfilePhoto from '../components/ProfilePhoto.astro';
import { getCollection } from 'astro:content';
import { site, skills } from '../data/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const projects = (await getCollection('projects'))
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3);

const recent = posts.slice(0, 4);
const fmt = (d: Date) => d.toLocaleDateString('es-ES', { month: 'short', year: 'numeric' });
---

<BaseLayout path="/">
  <section class="session">
    <div class="session__hero">
      <ProfilePhoto />
      <div class="session__cmds">
        <div class="session__block">
          <p class="session__line"><span class="prompt">$</span> <span class="cmd">whoami</span></p>
          <p class="session__out session__out--name">{site.name}</p>
          <p class="session__out session__out--role">{site.role}</p>
        </div>
        <div class="session__block">
          <p class="session__line"><span class="prompt">$</span> <span class="cmd">cat about.txt</span></p>
          <p class="session__out session__out--bio">{site.bio}</p>
        </div>
        <div class="session__block">
          <p class="session__line"><span class="prompt">$</span> <span class="cmd">ls skills/</span></p>
          <p class="skills-line">
            {skills.map((s) => <span>{s}</span>)}
          </p>
        </div>
        <p class="session__line"><span class="prompt">$</span> <span class="session__cursor"></span></p>
      </div>
    </div>
  </section>

  <div class="home-grid">
    <TermBlock cmd="ls blog/">
      <FeedList
        items={recent.map((p) => ({
          href: `/blog/${p.id}`,
          title: p.data.title,
          meta: fmt(p.data.pubDate),
        }))}
        dir
      />
      <a class="mt-link" href="/blog">./blog →</a>
    </TermBlock>

    <TermBlock cmd="ls proyectos/">
      <FeedList
        items={projects.map((p) => ({
          href: `/proyectos/${p.id}`,
          title: p.data.title,
          meta: String(p.data.year),
        }))}
        dir
      />
      <a class="mt-link" href="/proyectos">./proyectos →</a>
    </TermBlock>
  </div>
</BaseLayout>
