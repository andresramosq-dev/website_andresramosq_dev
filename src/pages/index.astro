---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostTile from '../components/PostTile.astro';
import ArtIllus from '../components/ArtIllus.astro';
import { getCollection } from 'astro:content';
import { site, categories } from '../data/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const [featured, ...rest] = posts;
---

<BaseLayout>
  <div class="wrap">
    <section class="hero">
      <div>
        <p class="hero__tag">Blog · diseño · código</p>
        <h1>{site.name}</h1>
        <p class="hero__lead">{site.tagline}</p>
        <div class="hero__btns">
          <a class="btn btn--dark" href="/blog">Ver artículos</a>
          <a class="btn btn--light" href="/proyectos">Proyectos</a>
        </div>
      </div>
      <div class="hero__visual">
        <ArtIllus variant="hero" />
      </div>
    </section>
  </div>

  <section class="sec">
    <div class="wrap">
      <div class="sec__head">
        <h2 class="sec__title">Artículos</h2>
        <a class="sec__more" href="/blog">Ver todos →</a>
      </div>
      <div class="post-grid">
        {featured && (
          <PostTile
            href={`/blog/${featured.id}`}
            title={featured.data.title}
            description={featured.data.description}
            date={featured.data.pubDate}
            minutes={featured.data.minutes}
            category={featured.data.category}
            featured
          />
        )}
        {rest.slice(0, 2).map((post) => (
          <PostTile
            href={`/blog/${post.id}`}
            title={post.data.title}
            description={post.data.description}
            date={post.data.pubDate}
            minutes={post.data.minutes}
            category={post.data.category}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div class="sec__head">
        <h2 class="sec__title">Categorías</h2>
        <a class="sec__more" href="/categorias">Ver todas →</a>
      </div>
      <div class="cat-row">
        {categories.map((cat) => (
          <a class="cat-pill" href={`/categorias/${cat.id}`}>
            <div class="cat-pill__art">
              <ArtIllus variant={cat.id} />
            </div>
            <p class="cat-pill__label">{cat.label}</p>
            <p class="cat-pill__desc">{cat.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
