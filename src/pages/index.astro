---
import BaseLayout from '../layouts/BaseLayout.astro';
import IdeaNode from '../components/IdeaNode.astro';
import BoardLines from '../components/BoardLines.astro';
import { getCollection } from 'astro:content';
import { site, categories } from '../data/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const connections = [
  { d: 'M50 44 C34 28, 16 20, 12 16' },
  { d: 'M50 44 C64 26, 80 14, 90 12' },
  { d: 'M50 44 C56 60, 70 74, 88 84' },
  { d: 'M50 44 C36 58, 20 70, 10 80' },
  { d: 'M50 44 C44 54, 38 60, 32 64' },
  { d: 'M50 44 C54 34, 50 28, 48 26' },
  { d: 'M50 44 C62 50, 76 52, 86 50' },
  { d: 'M50 44 C52 68, 50 72, 48 74' },
  { d: 'M12 16 C24 18, 44 22, 48 26', dashed: true },
  { d: 'M90 12 C78 18, 54 22, 48 26', dashed: true },
  { d: 'M86 50 C72 46, 58 40, 48 26', dashed: true },
];
---

<BaseLayout>
  <section class="idea-board" aria-label="Mapa de ideas">
    <img class="board-canvas" src="/images/board-canvas.svg" alt="" width="1400" height="900" />
    <BoardLines lines={connections} />

    <IdeaNode
      class="idea--hub"
      href="/"
      title={site.name}
      subtitle="dev · diseño · oficio"
      icon="code"
      color="#e8e4dc"
      size="lg"
      frame={1}
    />

    <IdeaNode
      class="idea--escritos"
      href="/blog"
      title="escritos"
      subtitle="blog"
      icon="book"
      color="#56d4dd"
      frame={2}
    />

    <IdeaNode
      class="idea--proyectos"
      href="/proyectos"
      title="proyectos"
      subtitle="build"
      icon="folder"
      color="#bc8cff"
      frame={3}
    />

    <IdeaNode
      class="idea--temas"
      href="/categorias"
      title="temas"
      subtitle="explore"
      icon="tag"
      color="#e3b341"
      frame={4}
    />

    <IdeaNode
      class="idea--sobre"
      href="/sobre"
      title="sobre"
      subtitle="about"
      icon="user"
      color="#ff7b72"
      frame={5}
    />

    {
      posts.map((post, i) => {
        const cat = categories.find((c) => c.id === post.data.category)!;
        return (
          <IdeaNode
            class={`idea--post-${i + 1}`}
            href={`/blog/${post.id}`}
            title={post.data.title}
            subtitle={post.data.pubDate.toLocaleDateString('es-ES', {
              day: 'numeric',
              month: 'short',
            })}
            icon={cat.icon}
            color={cat.color}
            size="sm"
            frame={((i + 1) % 5 + 1) as 1 | 2 | 3 | 4 | 5}
          />
        );
      })
    }

    <IdeaNode
      class="idea--cat-1"
      href={`/categorias/${categories[0].id}`}
      title={categories[0].label}
      subtitle="tema"
      icon={categories[0].icon}
      color={categories[0].color}
      size="sm"
      frame={2}
    />

    <IdeaNode
      class="idea--cat-2"
      href={`/categorias/${categories[1].id}`}
      title={categories[1].label}
      subtitle="tema"
      icon={categories[1].icon}
      color={categories[1].color}
      size="sm"
      frame={4}
    />

    <p class="board-label">mapa de ideas · clic en cualquier nota</p>
  </section>
</BaseLayout>
