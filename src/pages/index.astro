---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, categories } from '../data/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featured = posts.find((post) => post.data.featured) ?? posts[0];
const rest = posts.filter((post) => post.id !== featured.id);
---

<BaseLayout title={site.name} description={site.tagline} currentPath="/" mural>
	<div class="mural-page">
		<div class="mural" role="region" aria-label="Pizarra artística del blog">
			<img
				class="mural__art"
				src="/images/chalk-mural.svg"
				alt="Mural de pizarra artística con dibujos de tiza: planta, café, libro, bombilla y flechas"
				width="1600"
				height="1100"
			/>

			<div class="mural__hotspots">
				<div class="chalk-write chalk-write--brand">
					<span class="chalk-write__label">pizarra artística</span>
					<span class="chalk-write__title">{site.name}</span>
					<span class="chalk-write__hint">{site.tagline}</span>
				</div>

				<a class="chalk-write chalk-write--feat" href={`/blog/${featured.id}`}>
					<span class="chalk-write__label">★ empieza aquí</span>
					<span class="chalk-write__title">{featured.data.title}</span>
					<span class="chalk-write__hint">{featured.data.minutes} min</span>
				</a>

				{
					rest[0] && (
						<a class="chalk-write chalk-write--p1" href={`/blog/${rest[0].id}`}>
							<span class="chalk-write__label">nota</span>
							<span class="chalk-write__title">{rest[0].data.title}</span>
						</a>
					)
				}

				{
					rest[1] && (
						<a class="chalk-write chalk-write--p2" href={`/blog/${rest[1].id}`}>
							<span class="chalk-write__label">nota</span>
							<span class="chalk-write__title">{rest[1].data.title}</span>
						</a>
					)
				}

				{
					rest[2] && (
						<a class="chalk-write chalk-write--p3" href={`/blog/${rest[2].id}`}>
							<span class="chalk-write__label">nota</span>
							<span class="chalk-write__title">{rest[2].data.title}</span>
						</a>
					)
				}

				<a class="chalk-write chalk-write--about" href="/sobre">
					<span class="chalk-write__label">sobre</span>
					<span class="chalk-write__title">quién escribe</span>
					<span class="chalk-write__hint">bio + contacto</span>
				</a>

				<div class="chalk-write chalk-write--topics">
					<span class="chalk-write__label">temas en la pizarra</span>
					<span class="chalk-write__title">categorías</span>
					<div class="topic-row">
						{
							categories.map((category) => (
								<a href={`/categorias/${category.id}`}>{category.label}</a>
							))
						}
					</div>
				</div>
			</div>
		</div>

		<p class="mural-caption">
			<span>el dibujo es la navegación — toca lo que está escrito con tiza</span>
			<a href="/blog">ver muro de escritos →</a>
		</p>
	</div>
</BaseLayout>
