---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, categories } from '../data/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title={site.name} description={site.tagline} currentPath="/">
	<section class="hero">
		<div>
			<p class="hero__eyebrow">cuaderno personal</p>
			<h1 class="hero__title">
				Andrés<br />
				<span>Ramos</span>
			</h1>
			<p class="hero__lead">{site.bio}</p>
			<div class="hero__actions">
				<a class="link-plain" href="/blog">Leer escritos</a>
				<a class="link-soft" href="/sobre">Sobre mí</a>
			</div>
		</div>
		<div class="hero__art">
			<img
				src="/images/art-hero.svg"
				alt="Ilustración artística abstracta con gestos de tinta, planta y lápiz"
				width="800"
				height="700"
			/>
		</div>
	</section>

	<section class="writing" aria-labelledby="writing-title">
		<div class="writing__head">
			<h2 class="writing__title" id="writing-title">Escritos</h2>
			<a class="link-soft" href="/blog">Ver todos</a>
		</div>

		{
			posts.slice(0, 5).map((post) => (
				<a class="entry" href={`/blog/${post.id}`}>
					<span class="entry__date">
						{post.data.pubDate.toLocaleDateString('es-ES', {
							year: 'numeric',
							month: 'short',
						})}
					</span>
					<span class="entry__title">{post.data.title}</span>
					<span class="entry__cat">{post.data.category}</span>
					<span class="entry__desc">{post.data.description}</span>
				</a>
			))
		}
	</section>

	<section class="topics" aria-labelledby="topics-title">
		<h2 class="topics__title" id="topics-title">Temas</h2>
		<ul class="topics__list">
			{
				categories.map((category) => (
					<li>
						<a href={`/categorias/${category.id}`}>{category.label}</a>
					</li>
				))
			}
		</ul>
	</section>

	<section class="about-flow">
		<img class="about-flow__mark" src="/images/art-mark.svg" alt="" width="120" height="120" />
		<div>
			<h2>Hecho a mano, pensado con calma</h2>
			<p>{site.tagline} Sin ruido visual: tipografía, ilustración y lectura.</p>
			<a class="link-plain" href="/sobre">Conocer al autor</a>
		</div>
	</section>
</BaseLayout>
