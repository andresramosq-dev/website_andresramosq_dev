---
import BaseLayout from '../layouts/BaseLayout.astro';
import TermBlock from '../components/TermBlock.astro';
import FeedList from '../components/FeedList.astro';
import ProfilePhoto from '../components/ProfilePhoto.astro';
import { getCollection } from 'astro:content';
import { site } from '../data/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const projects = (await getCollection('projects'))
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3);

const recent = posts.slice(0, 4);
const fmt = (d: Date) => d.toLocaleDateString('es-ES', { month: 'short', year: 'numeric' });
---

<BaseLayout path="/">
  <section class="hero">
    <ProfilePhoto />
    <div>
      <p class="hero__domain">{site.domain}</p>
      <h1 class="hero__name">{site.name}</h1>
      <p class="hero__role">{site.role}</p>
      <p class="hero__bio">{site.bio}</p>
      <a class="hero__link" href="/sobre">cat sobre.md →</a>
    </div>
  </section>

  <TermBlock cmd="ls -la blog/">
    <FeedList
      items={recent.map((p) => ({
        href: `/blog/${p.id}`,
        title: `${p.id}.md`,
        meta: fmt(p.data.pubDate),
      }))}
    />
    <a class="mt-link" href="/blog">cd blog/ →</a>
  </TermBlock>

  <TermBlock cmd="ls -la proyectos/">
    <FeedList
      items={projects.map((p) => ({
        href: `/proyectos/${p.id}`,
        title: p.id,
        meta: String(p.data.year),
      }))}
    />
    <a class="mt-link" href="/proyectos">cd proyectos/ →</a>
  </TermBlock>
</BaseLayout>
