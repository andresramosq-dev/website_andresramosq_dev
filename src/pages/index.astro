---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostList from '../components/PostList.astro';
import Icon from '../components/Icon.astro';
import { site } from '../data/site';
---

<BaseLayout title={site.name} description={site.tagline} currentPath="/">
	<section class="intro">
		<div>
			<p class="intro__label">
				<Icon name="pen" size={16} />
				Blog personal
			</p>
			<h1 class="intro__title">{site.name}</h1>
			<p class="intro__text">{site.tagline}</p>
			<div class="intro__actions">
				<a class="btn btn--solid" href="#escritos">
					Ver escritos
					<Icon name="arrow" size={18} />
				</a>
				<a class="btn btn--ghost" href="/sobre">Sobre mí</a>
			</div>
		</div>
		<div class="intro__art">
			<img
				src="/images/hero-blog.svg"
				alt="Ilustración de un cuaderno, notas y lápiz"
				width="640"
				height="420"
			/>
		</div>
	</section>

	<section class="section" id="escritos" aria-labelledby="escritos-title">
		<div class="section__head">
			<h2 class="section__title" id="escritos-title">
				<Icon name="book" size={22} />
				Escritos
			</h2>
			<p class="section__note">Lo más reciente primero</p>
		</div>
		<PostList />
	</section>
</BaseLayout>
