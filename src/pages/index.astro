---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import CategoryBadge from '../components/CategoryBadge.astro';
import PostCard from '../components/PostCard.astro';
import { site, categories } from '../data/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featured = posts.find((post) => post.data.featured) ?? posts[0];
const latest = posts.filter((post) => post.id !== featured.id).slice(0, 4);
---

<BaseLayout title={site.name} description={site.tagline} currentPath="/">
	<section class="hero">
		<div>
			<p class="hero__kicker">
				<Icon name="pen" size={16} />
				pizarra artística
			</p>
			<h1 class="hero__title">
				{site.name}
			</h1>
			<p class="hero__text">
				{site.tagline} Ideas dibujadas a mano: código, diseño y oficio sobre una pizarra creativa.
			</p>
			<div class="hero__actions">
				<a class="btn btn--solid" href="/blog">
					Ver escritos
					<Icon name="arrow" size={17} />
				</a>
				<a class="btn btn--ghost" href="/sobre">Sobre mí</a>
			</div>
		</div>
		<div class="hero__art">
			<img
				src="/images/hero-blog.svg"
				alt="Ilustración de un cuaderno y una planta"
				width="640"
				height="420"
			/>
		</div>
	</section>

	<section class="section" aria-labelledby="featured-title">
		<div class="section__head">
			<h2 class="section__title" id="featured-title">Destacado</h2>
		</div>
		<a class="featured" href={`/blog/${featured.id}`}>
			<div>
				<div class="featured__meta">
					<CategoryBadge id={featured.data.category} />
					<span>
						{featured.data.pubDate.toLocaleDateString('es-ES', {
							year: 'numeric',
							month: 'short',
							day: 'numeric',
						})}
					</span>
					<span>{featured.data.minutes} min</span>
				</div>
				<h3 class="featured__title">{featured.data.title}</h3>
				<p class="featured__desc">{featured.data.description}</p>
				<span class="featured__cta">
					Leer artículo
					<Icon name="arrow" size={16} />
				</span>
			</div>
			<div class="featured__art">
				<img src="/images/mark-featured.svg" alt="" width="220" height="160" />
			</div>
		</a>
	</section>

	<section class="section" aria-labelledby="latest-title">
		<div class="section__head">
			<h2 class="section__title" id="latest-title">Últimos escritos</h2>
			<a class="section__link" href="/blog">
				Archivo
				<Icon name="arrow" size={15} />
			</a>
		</div>
		<div class="post-grid">
			{latest.map((post) => <PostCard post={post} />)}
		</div>
	</section>

	<section class="section" aria-labelledby="cats-title">
		<div class="section__head">
			<h2 class="section__title" id="cats-title">Temas</h2>
			<a class="section__link" href="/categorias">
				Ver todos
				<Icon name="arrow" size={15} />
			</a>
		</div>
		<div class="cat-grid">
			{
				categories.map((category) => (
					<a class="cat-card" href={`/categorias/${category.id}`}>
						<div class="cat-card__icon">
							<Icon name={category.icon} size={17} />
						</div>
						<h3 class="cat-card__title">{category.label}</h3>
						<p class="cat-card__desc">{category.description}</p>
					</a>
				))
			}
		</div>
	</section>

	<section class="about-band" aria-labelledby="about-band-title">
		<div>
			<h2 id="about-band-title">Sobre este blog</h2>
			<p>{site.bio}</p>
			<a class="btn btn--ghost" href="/sobre">
				Más sobre mí
				<Icon name="arrow" size={17} />
			</a>
		</div>
		<div class="about-band__stats">
			<div class="stat">
				<strong>{posts.length}</strong>
				<span>artículos</span>
			</div>
			<div class="stat">
				<strong>{categories.length}</strong>
				<span>temas</span>
			</div>
			<div class="stat">
				<strong>Astro</strong>
				<span>publicado con</span>
			</div>
		</div>
	</section>
</BaseLayout>
