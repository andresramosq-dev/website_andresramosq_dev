---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, categories } from '../data/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featured = posts.find((post) => post.data.featured) ?? posts[0];
const latest = posts.filter((post) => post.id !== featured.id).slice(0, 3);
---

<BaseLayout title={site.name} description={site.tagline} currentPath="/" board>
	<div class="board-page">
		<div class="board" aria-label="Pizarra artística del blog">
			<!-- chalk connector lines between frames -->
			<svg class="board__canvas" viewBox="0 0 1000 980" preserveAspectRatio="none" aria-hidden="true">
				<path d="M340 140 C420 160, 480 170, 560 180"></path>
				<path d="M300 320 C360 360, 400 390, 430 430"></path>
				<path d="M680 300 C700 380, 720 450, 760 520"></path>
				<path d="M250 560 C320 620, 380 700, 420 760"></path>
				<path d="M700 640 C640 700, 560 760, 500 800"></path>
				<path d="M180 200 C160 280, 150 340, 170 400"></path>
				<!-- arrow heads -->
				<path class="board__arrowhead" d="M555 172 l18 4 -12 14 z"></path>
				<path class="board__arrowhead" d="M425 425 l14 -10 4 18 z"></path>
				<path class="board__arrowhead" d="M755 515 l8 16 -18 -2 z"></path>
			</svg>

			<img class="doodle doodle--star" src="/images/doodles/star.svg" alt="" width="48" height="48" />
			<img class="doodle doodle--coffee" src="/images/doodles/coffee.svg" alt="" width="58" height="58" />
			<img class="doodle doodle--leaf" src="/images/doodles/leaf.svg" alt="" width="70" height="70" />
			<img class="doodle doodle--bulb" src="/images/doodles/bulb.svg" alt="" width="54" height="54" />
			<img class="doodle doodle--arrow-1" src="/images/doodles/arrow-curve.svg" alt="" width="120" height="70" />
			<img class="doodle doodle--arrow-2" src="/images/doodles/arrow-curve.svg" alt="" width="110" height="65" />

			<section class="frame frame--title">
				<p class="frame__label">pizarra artística</p>
				<h1 class="frame__title">{site.name}</h1>
				<p class="frame__text">{site.tagline}</p>
				<p class="frame__cta">← empieza por cualquier recuadro</p>
			</section>

			<a class="frame frame--featured" href={`/blog/${featured.id}`}>
				<p class="frame__label">destacado ★</p>
				<h2 class="frame__title">{featured.data.title}</h2>
				<p class="frame__text">{featured.data.description}</p>
				<div class="frame__meta">
					<span>{featured.data.category}</span>
					<span>{featured.data.minutes} min</span>
				</div>
				<span class="frame__cta">leer esto →</span>
			</a>

			<div class="frame frame--note" aria-hidden="true">
				<p class="frame__label">nota</p>
				<p class="frame__title" style="font-size: 1.5rem;">ideas sueltas</p>
				<p class="frame__text">flechas · doodles · recuadros</p>
			</div>

			{
				latest[0] && (
					<a class="frame frame--post-1" href={`/blog/${latest[0].id}`}>
						<p class="frame__label">escrito</p>
						<h2 class="frame__title">{latest[0].data.title}</h2>
						<p class="frame__text">{latest[0].data.description}</p>
					</a>
				)
			}

			{
				latest[1] && (
					<a class="frame frame--post-2" href={`/blog/${latest[1].id}`}>
						<p class="frame__label">escrito</p>
						<h2 class="frame__title">{latest[1].data.title}</h2>
						<p class="frame__text">{latest[1].data.description}</p>
					</a>
				)
			}

			{
				latest[2] && (
					<a class="frame frame--post-3" href={`/blog/${latest[2].id}`}>
						<p class="frame__label">escrito</p>
						<h2 class="frame__title">{latest[2].data.title}</h2>
						<p class="frame__text">{latest[2].data.description}</p>
					</a>
				)
			}

			<section class="frame frame--topics">
				<p class="frame__label">temas</p>
				<h2 class="frame__title">categorías</h2>
				<div class="topics">
					{
						categories.map((category) => (
							<a href={`/categorias/${category.id}`}>{category.label}</a>
						))
					}
				</div>
			</section>

			<section class="frame frame--about">
				<p class="frame__label">sobre</p>
				<h2 class="frame__title">quién escribe</h2>
				<p class="frame__text">{site.bio}</p>
				<a class="frame__cta" href="/sobre">más sobre mí →</a>
			</section>
		</div>

		<p class="board-legend">
			<span>arrastra la mirada, no el scroll perfecto</span>
			<a href="/blog">archivo completo →</a>
		</p>
	</div>
</BaseLayout>
