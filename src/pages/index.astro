---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { site } from '../data/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout>
  <section class="chalk-canvas" aria-label="Inicio artístico">
    <img class="chalk-scene" src="/images/chalk-scene.svg" alt="" width="1200" height="900" />

    <a class="chalk-write w-title" href="/">
      <span class="chalk-write-main">{site.name}</span>
      <span class="chalk-write-sub">{site.tagline}</span>
    </a>

    <a class="chalk-write w-about" href="/sobre">
      <span class="chalk-write-main">Sobre mí</span>
      <span class="chalk-write-sub">quién escribe aquí</span>
    </a>

    <a class="chalk-write w-blog" href="/blog">
      <span class="chalk-write-main">Escritos</span>
      <span class="chalk-write-sub">ideas, notas, reflexiones</span>
    </a>

    <a class="chalk-write w-cat" href="/categorias">
      <span class="chalk-write-main">Temas</span>
      <span class="chalk-write-sub">diseño · código · oficio</span>
    </a>

    <a class="chalk-write w-proj" href="/proyectos">
      <span class="chalk-write-main">Proyectos</span>
      <span class="chalk-write-sub">cosas que construyo</span>
    </a>

    {
      posts.map((post, i) => (
        <a class={`chalk-write w-post-${i + 1}`} href={`/blog/${post.id}`}>
          <span class="chalk-write-main">{post.data.title}</span>
          <span class="chalk-write-sub">
            {post.data.pubDate.toLocaleDateString('es-ES', { day: 'numeric', month: 'short' })}
          </span>
        </a>
      ))
    }
  </section>
</BaseLayout>
