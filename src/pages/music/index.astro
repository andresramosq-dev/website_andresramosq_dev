---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CmdBlock from '../../components/CmdBlock.astro';
import SpotifyEmbed from '../../components/SpotifyEmbed.astro';
import { tastes } from '../../data/site';
---

<BaseLayout title="music" path="/music" description="Playlist — Spotify embed">
	<CmdBlock cmd={'play "I\'m a programmer"'} cwd="~/music" id="music-player">
		<div class="music-page">
			<p class="music-page__notice" role="note">
				You need an active Spotify session in this browser to play music here. Log in at
				<a href="https://open.spotify.com" target="_blank" rel="noreferrer">open.spotify.com</a>
				if playback is limited to previews.
			</p>
			<p class="music-page__line">
				<span class="music-page__key">playlist</span>
				<span class="music-page__sep">=</span>
				<span class="music-page__val">{tastes.spotify.playlistLabel}</span>
			</p>
			<SpotifyEmbed />
		</div>
	</CmdBlock>
</BaseLayout>
