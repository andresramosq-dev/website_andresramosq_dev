---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TermPath from '../../components/TermPath.astro';
import SectionPath from '../../components/SectionPath.astro';
import TermPanel from '../../components/TermPanel.astro';
import ProfilePhoto from '../../components/ProfilePhoto.astro';
import { site, skills, now, principles } from '../../data/site';

const allSkills = [...skills.frontend, ...skills.backend, ...skills.tools];
---

<BaseLayout title="sobre mí" path="/andres">
  <TermPath path="/andres" />

  <section class="about-section">
    <SectionPath id="perfil" />
    <TermPanel label="perfil">
      <div class="about-hero">
        <ProfilePhoto size="md" />
        <div class="about-hero__info">
          <p class="about-hero__name">{site.name}</p>
          <p class="about-hero__role">{site.role} · {site.location}</p>
          <dl class="kv kv--grid">
            <div><dt>email</dt><dd><a href={`mailto:${site.email}`}>{site.email}</a></dd></div>
            <div><dt>github</dt><dd><a href={site.links[0].href} target="_blank" rel="noreferrer">{site.handle}</a></dd></div>
            <div><dt>desde</dt><dd>{site.since}</dd></div>
            <div><dt>web</dt><dd>{site.domain}</dd></div>
          </dl>
        </div>
      </div>
    </TermPanel>
  </section>

  <section class="about-section">
    <SectionPath id="bio" />
    <TermPanel label="bio.txt">
      <div class="prose">
        <p class="prose__lead">{site.bio}</p>
        {site.about.map((p) => <p>{p}</p>)}
      </div>
    </TermPanel>
  </section>

  <section class="about-section">
    <SectionPath id="now" />
    <TermPanel label="now.txt">
      <dl class="now-grid">
        <div class="now-item">
          <dt>working_on</dt>
          <dd>{now.working}</dd>
        </div>
        <div class="now-item">
          <dt>learning</dt>
          <dd>{now.learning}</dd>
        </div>
        <div class="now-item">
          <dt>reading</dt>
          <dd>{now.reading}</dd>
        </div>
      </dl>
    </TermPanel>
  </section>

  <section class="about-section">
    <SectionPath id="skills" />
    <TermPanel label="skills/">
      <p class="skills-line">
        {allSkills.map((s) => <span>{s}</span>)}
      </p>
    </TermPanel>
  </section>

  <section class="about-section">
    <SectionPath id="principles" />
    <TermPanel label="principles.txt">
      <div class="principles">
        {principles.map((p) => (
          <div class="principle">
            <p class="principle__title">{p.title}</p>
            <p class="principle__desc">{p.desc}</p>
          </div>
        ))}
      </div>
    </TermPanel>
  </section>
</BaseLayout>
