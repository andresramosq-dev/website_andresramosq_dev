---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CmdBlock from '../../components/CmdBlock.astro';
import BlogPostList from '../../components/blog/BlogPostList.astro';
import BlogTagNav from '../../components/blog/BlogTagNav.astro';
import { categories } from '../../data/site';
import type { CategoryId } from '../../data/site';
import { getCollection } from 'astro:content';
import {
	buildPostIndex,
	indexCategoryIds,
	indexTagNames,
	resolvePostsFromIndex,
} from '../../lib/blog-index';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const postIndex = buildPostIndex(allPosts);
const postsById = new Map(allPosts.map((p) => [p.id, p]));

const usedCategories = categories.filter((c) => indexCategoryIds(postIndex).includes(c.id));
const allTags = indexTagNames(postIndex);

const categoryParam = Astro.url.searchParams.get('category');
const tagParam = Astro.url.searchParams.get('tag');

let activeCategory: CategoryId | 'all' = 'all';
let activeTag: string | 'all' = 'all';

if (tagParam && postIndex.byTag[tagParam]) {
	activeTag = tagParam;
} else if (categoryParam && postIndex.byCategory[categoryParam as CategoryId]) {
	activeCategory = categoryParam as CategoryId;
}

const posts = resolvePostsFromIndex(postIndex, postsById, {
	category: activeCategory,
	tag: activeTag,
});

const categoryLabels = Object.fromEntries(usedCategories.map((c) => [c.id, c.label]));
---

<BaseLayout title="posts" path="/posts">
	<div class="console-session">
		{postIndex.all.length > 0 && (
			<CmdBlock cmd="filter --list" cwd="~/posts" transcript id="posts-filters">
				<BlogTagNav
					activeCategory={activeCategory}
					activeTag={activeTag}
					categories={usedCategories}
					tags={allTags}
					categoryLabels={categoryLabels}
				/>
			</CmdBlock>
		)}

		<CmdBlock cmd="ls posts/" cwd="~/posts" transcript id="posts-index">
			{postIndex.all.length === 0 ? (
				<p class="route-stub">
					<span class="route-stub__muted">#</span> no posts yet — add a <code>.md</code> file under{' '}
					<code>src/content/blog/</code>
				</p>
			) : posts.length === 0 ? (
				<p class="route-stub">
					<span class="route-stub__muted">#</span> no posts match this filter —{' '}
					<a class="posts-index__filter-reset" href="/posts" data-astro-reload>show all</a>
				</p>
			) : (
				<BlogPostList posts={posts} />
			)}
		</CmdBlock>
	</div>
</BaseLayout>
